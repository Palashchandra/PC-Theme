{{ 'section-faq-bootstrap-accordion.css' | asset_url | stylesheet_tag }}

<section
  id="FaqBootstrapAccordion-{{ section.id }}"
  class="faq-bootstrap-accordion color-{{ section.settings.color_scheme }} gradient"
  style="
    --faq-padding-top-mobile: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    --faq-padding-bottom-mobile: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    --faq-padding-top-desktop: {{ section.settings.padding_top }}px;
    --faq-padding-bottom-desktop: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="page-width">
    <div class="faq-bootstrap-accordion-inner">
      {%- if section.settings.title != blank or section.settings.description != blank -%}
        <div class="faq-bootstrap-accordion-header">
          {%- if section.settings.title != blank -%}
            <h2 class="faq-bootstrap-accordion-title inline-richtext">{{ section.settings.title }}</h2>
          {%- endif -%}

          {%- if section.settings.description != blank -%}
            <div class="faq-bootstrap-accordion-description rte">
              {{ section.settings.description }}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}

      <div
        class="accordion faq-bootstrap-accordion-list"
        id="FaqBootstrapAccordionList-{{ section.id }}"
      >
        {%- for block in section.blocks -%}
          {%- assign faq_open = false -%}
          {%- if section.settings.open_first_item and forloop.first -%}
            {%- assign faq_open = true -%}
          {%- endif -%}

          <div class="accordion-item faq-bootstrap-accordion-item" {{ block.shopify_attributes }}>
            <h3 class="accordion-header faq-bootstrap-accordion-heading" id="FaqHeading-{{ block.id }}">
              <button
                class="accordion-button faq-bootstrap-accordion-button{% unless faq_open %} collapsed{% endunless %}"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#FaqCollapse-{{ block.id }}"
                aria-expanded="{% if faq_open %}true{% else %}false{% endif %}"
                aria-controls="FaqCollapse-{{ block.id }}"
              >
                <span class="faq-bootstrap-accordion-button-text">
                  {{ block.settings.question | escape }}
                </span>
                <span class="faq-bootstrap-accordion-button-icon" aria-hidden="true">
                  {% render 'icon-caret' %}
                </span>
              </button>
            </h3>

            <div
              id="FaqCollapse-{{ block.id }}"
              class="accordion-collapse collapse{% if faq_open %} show{% endif %}"
              aria-labelledby="FaqHeading-{{ block.id }}"
              data-bs-parent="#FaqBootstrapAccordionList-{{ section.id }}"
            >
              <div class="accordion-body faq-bootstrap-accordion-body rte">
                {{ block.settings.answer }}
              </div>
            </div>
          </div>
        {%- else -%}
          <div class="accordion-item faq-bootstrap-accordion-item">
            <h3 class="accordion-header faq-bootstrap-accordion-heading">
              <button
                class="accordion-button faq-bootstrap-accordion-button"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#FaqCollapsePlaceholder-{{ section.id }}"
                aria-expanded="true"
                aria-controls="FaqCollapsePlaceholder-{{ section.id }}"
              >
                <span class="faq-bootstrap-accordion-button-text">Frequently asked question</span>
                <span class="faq-bootstrap-accordion-button-icon" aria-hidden="true">
                  {% render 'icon-caret' %}
                </span>
              </button>
            </h3>
            <div
              id="FaqCollapsePlaceholder-{{ section.id }}"
              class="accordion-collapse collapse show"
            >
              <div class="accordion-body faq-bootstrap-accordion-body rte">
                <p>Add FAQ blocks from the theme editor to populate this section.</p>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ accordion",
  "tag": "section",
  "class": "section",
  "max_blocks": 12,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "Frequently asked questions",
      "label": "Section title"
    },
    {
      "type": "richtext",
      "id": "description",
      "default": "<p>Use this section to answer shipping, returns, product, or payment questions in a clean accordion layout.</p>",
      "label": "Section description"
    },
    {
      "type": "checkbox",
      "id": "open_first_item",
      "default": true,
      "label": "Open first item"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        {
          "value": "accent-1",
          "label": "Accent 1"
        },
        {
          "value": "accent-2",
          "label": "Accent 2"
        },
        {
          "value": "background-1",
          "label": "Background 1"
        },
        {
          "value": "background-2",
          "label": "Background 2"
        },
        {
          "value": "inverse",
          "label": "Inverse"
        }
      ],
      "default": "background-1",
      "label": "Color scheme"
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "default": "How long does shipping take?",
          "label": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "default": "<p>Share your shipping timeline here so customers know exactly what to expect after placing an order.</p>",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ accordion",
      "blocks": [
        {
          "type": "faq_item"
        },
        {
          "type": "faq_item"
        },
        {
          "type": "faq_item"
        },
        {
          "type": "faq_item"
        }
      ]
    }
  ]
}
{% endschema %}
