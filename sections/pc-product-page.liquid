{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-loading-overlay.css' | asset_url | stylesheet_tag }}
{{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}
{{ 'component-rating.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'section-related-products.css' | asset_url | stylesheet_tag }}

<script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'product-form.js' | asset_url }}" defer="defer" type="module"></script>

{%- style -%}
/* ============================================================
   PC PRODUCT PAGE — Custom Styles
   ============================================================ */

/* --- Breadcrumb Banner ------------------------------------ */
.pc-breadcrumb-banner {
  background-color: {{ section.settings.breadcrumb_bg_color }};
  padding: 20px 0;
  border-bottom: 1px solid rgba(0,0,0,0.08);
}
.pc-breadcrumb-inner {
  max-width: {{ settings.page_width }}px;
  margin: 0 auto;
  padding: 0 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 8px;
}
.pc-breadcrumb-nav {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 1.3rem;
  color: {{ section.settings.breadcrumb_text_color }};
}
.pc-breadcrumb-nav a {
  color: {{ section.settings.breadcrumb_text_color }};
  text-decoration: none;
  opacity: 0.8;
  transition: opacity 0.2s;
}
.pc-breadcrumb-nav a:hover { opacity: 1; text-decoration: underline; }
.pc-breadcrumb-nav .pc-breadcrumb-sep {
  opacity: 0.5;
  font-size: 1.1rem;
}
.pc-breadcrumb-nav .pc-breadcrumb-current {
  font-weight: 600;
  opacity: 1;
}
.pc-breadcrumb-title {
  font-size: 1.8rem;
  font-weight: 700;
  color: {{ section.settings.breadcrumb_text_color }};
  margin: 0;
  line-height: 1.3;
}

/* --- Product Section -------------------------------------- */
.pc-product-section {
  max-width: {{ settings.page_width }}px;
  margin: 0 auto;
  padding: 40px 20px;
}
.pc-product-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 40px;
  align-items: start;
}
@media screen and (max-width: 989px) {
  .pc-product-grid { grid-template-columns: 1fr; gap: 30px; }
}

/* --- Gallery Column --------------------------------------- */
.pc-gallery-col {}
.pc-gallery-main {
  position: relative;
  background: #f8f8f8;
  border-radius: 8px;
  overflow: hidden;
  aspect-ratio: 1 / 1;
  cursor: zoom-in;
}
.pc-gallery-main img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
  transition: transform 0.3s ease;
}
.pc-gallery-main:hover img { transform: scale(1.04); }
.pc-gallery-badge {
  position: absolute;
  top: 14px;
  left: 14px;
  background: #e00;
  color: #fff;
  font-size: 1.1rem;
  font-weight: 700;
  padding: 4px 10px;
  border-radius: 4px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.pc-gallery-thumbs {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 8px;
  margin-top: 12px;
}
.pc-gallery-thumbs button {
  border: 2px solid transparent;
  border-radius: 6px;
  padding: 0;
  cursor: pointer;
  background: #f8f8f8;
  overflow: hidden;
  aspect-ratio: 1 / 1;
  transition: border-color 0.2s;
}
.pc-gallery-thumbs button.active,
.pc-gallery-thumbs button:hover {
  border-color: {{ section.settings.accent_color }};
}
.pc-gallery-thumbs button img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* --- Info Column ------------------------------------------ */
.pc-info-col {}
.pc-product-vendor {
  font-size: 1.2rem;
  color: #888;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 8px;
}
.pc-product-title {
  font-size: 2.6rem;
  font-weight: 700;
  line-height: 1.25;
  margin: 0 0 12px;
  color: #1a1a1a;
}
.pc-product-rating-row {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 16px;
}
.pc-stars {
  display: flex;
  gap: 2px;
  color: #f5a623;
  font-size: 1.6rem;
}
.pc-review-count {
  font-size: 1.3rem;
  color: #888;
}
.pc-price-block {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 20px;
  padding: 16px;
  background: #f8f9fa;
  border-radius: 8px;
}
.pc-price-current {
  font-size: 3rem;
  font-weight: 700;
  color: {{ section.settings.accent_color }};
  line-height: 1;
}
.pc-price-compare {
  font-size: 1.8rem;
  color: #aaa;
  text-decoration: line-through;
  line-height: 1;
}
.pc-price-saving {
  font-size: 1.2rem;
  background: #fff3f3;
  color: #e00;
  padding: 4px 8px;
  border-radius: 4px;
  font-weight: 600;
}
.pc-divider {
  height: 1px;
  background: #eee;
  margin: 20px 0;
}
.pc-variant-label {
  font-size: 1.4rem;
  font-weight: 600;
  margin-bottom: 8px;
  color: #333;
}
.pc-variant-options {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 20px;
}
.pc-qty-row {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 16px;
}
.pc-qty-label {
  font-size: 1.4rem;
  font-weight: 600;
  color: #333;
  min-width: 65px;
}
.pc-qty-input {
  display: flex;
  align-items: center;
  border: 1px solid #ddd;
  border-radius: 6px;
  overflow: hidden;
}
.pc-qty-btn {
  width: 38px;
  height: 38px;
  background: #f5f5f5;
  border: none;
  cursor: pointer;
  font-size: 1.8rem;
  font-weight: 600;
  color: #333;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s;
}
.pc-qty-btn:hover { background: #e9e9e9; }
.pc-qty-number {
  width: 50px;
  height: 38px;
  text-align: center;
  border: none;
  border-left: 1px solid #ddd;
  border-right: 1px solid #ddd;
  font-size: 1.4rem;
  font-weight: 600;
}
.pc-qty-number::-webkit-inner-spin-button,
.pc-qty-number::-webkit-outer-spin-button { -webkit-appearance: none; }

/* --- Action Buttons --------------------------------------- */
.pc-btn-group {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 20px;
}
.pc-btn-atc {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  width: 100%;
  padding: 16px 24px;
  background: {{ section.settings.accent_color }};
  color: #fff;
  font-size: 1.5rem;
  font-weight: 700;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  transition: opacity 0.2s, transform 0.1s;
}
.pc-btn-atc:hover { opacity: 0.9; transform: translateY(-1px); }
.pc-btn-atc:active { transform: translateY(0); }
.pc-btn-atc svg { width: 20px; height: 20px; fill: currentColor; }

.pc-btn-buy {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 15px 24px;
  background: #1a1a1a;
  color: #fff;
  font-size: 1.5rem;
  font-weight: 700;
  border: 2px solid #1a1a1a;
  border-radius: 8px;
  cursor: pointer;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  text-decoration: none;
  transition: background 0.2s, color 0.2s;
}
.pc-btn-buy:hover { background: #333; }

/* --- Product Meta ----------------------------------------- */
.pc-product-meta {
  display: flex;
  flex-direction: column;
  gap: 6px;
  font-size: 1.3rem;
  color: #555;
  margin-top: 12px;
}
.pc-product-meta span b { color: #222; }
.pc-stock-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-weight: 600;
}
.pc-stock-badge.in-stock { color: #2a9d2a; }
.pc-stock-badge.out-stock { color: #c00; }
.pc-stock-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  display: inline-block;
}
.in-stock .pc-stock-dot { background: #2a9d2a; }
.out-stock .pc-stock-dot { background: #c00; }

/* --- Tabs Section ----------------------------------------- */
.pc-tabs-section {
  max-width: {{ settings.page_width }}px;
  margin: 0 auto 50px;
  padding: 0 20px;
}
.pc-tabs-nav {
  display: flex;
  border-bottom: 2px solid #eee;
  margin-bottom: 0;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  gap: 0;
}
.pc-tab-btn {
  padding: 14px 28px;
  font-size: 1.5rem;
  font-weight: 600;
  color: #666;
  background: none;
  border: none;
  border-bottom: 3px solid transparent;
  margin-bottom: -2px;
  cursor: pointer;
  white-space: nowrap;
  transition: color 0.2s, border-color 0.2s;
  letter-spacing: 0.02em;
}
.pc-tab-btn:hover { color: {{ section.settings.accent_color }}; }
.pc-tab-btn.active {
  color: {{ section.settings.accent_color }};
  border-bottom-color: {{ section.settings.accent_color }};
}
.pc-tab-panels { border: 1px solid #eee; border-top: none; border-radius: 0 0 8px 8px; }
.pc-tab-panel {
  display: none;
  padding: 32px 32px;
  font-size: 1.4rem;
  line-height: 1.75;
  color: #333;
}
.pc-tab-panel.active { display: block; }
.pc-tab-panel h3 { margin-top: 0; font-size: 1.8rem; margin-bottom: 12px; }
.pc-tab-panel ul { padding-left: 20px; margin-bottom: 16px; }
.pc-tab-panel ul li { margin-bottom: 6px; }

/* Reviews Panel */
.pc-reviews-empty {
  text-align: center;
  padding: 40px 0;
  color: #888;
}
.pc-reviews-empty svg { width: 48px; height: 48px; opacity: 0.3; margin-bottom: 12px; }
.pc-review-summary {
  display: flex;
  align-items: center;
  gap: 24px;
  padding: 20px;
  background: #f9f9f9;
  border-radius: 8px;
  margin-bottom: 20px;
}
.pc-review-avg-score {
  font-size: 5rem;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1;
}
.pc-review-stars-large { font-size: 2rem; color: #f5a623; margin: 4px 0; }
.pc-review-count-label { font-size: 1.2rem; color: #888; }
.pc-write-review-btn {
  display: inline-block;
  padding: 12px 24px;
  background: {{ section.settings.accent_color }};
  color: #fff;
  font-size: 1.4rem;
  font-weight: 600;
  border-radius: 6px;
  text-decoration: none;
  margin-top: 10px;
  transition: opacity 0.2s;
}
.pc-write-review-btn:hover { opacity: 0.85; color: #fff; }

/* Shipping Info Panel */
.pc-info-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 20px;
}
.pc-info-card {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8px;
  padding: 20px;
  background: #f9f9f9;
  border-radius: 8px;
}
.pc-info-card svg {
  width: 28px;
  height: 28px;
  color: {{ section.settings.accent_color }};
  fill: {{ section.settings.accent_color }};
}
.pc-info-card h4 { margin: 0; font-size: 1.4rem; color: #222; }
.pc-info-card p { margin: 0; font-size: 1.2rem; color: #777; line-height: 1.5; }

/* --- Related Products ------------------------------------- */
.pc-related-section {
  background: {{ section.settings.related_bg_color }};
  padding: 50px 0;
}
.pc-related-inner {
  max-width: {{ settings.page_width }}px;
  margin: 0 auto;
  padding: 0 20px;
}
.pc-related-heading {
  font-size: 2.4rem;
  font-weight: 700;
  text-align: center;
  margin-bottom: 30px;
  color: #1a1a1a;
}
.pc-related-heading span {
  display: inline-block;
  border-bottom: 3px solid {{ section.settings.accent_color }};
  padding-bottom: 6px;
}
.pc-related-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
}
@media screen and (max-width: 989px) {
  .pc-related-grid { grid-template-columns: repeat(2, 1fr); }
}
@media screen and (max-width: 480px) {
  .pc-related-grid { grid-template-columns: 1fr; }
}
.pc-rel-card {
  background: #fff;
  border-radius: 10px;
  overflow: hidden;
  box-shadow: 0 2px 12px rgba(0,0,0,0.07);
  transition: box-shadow 0.25s, transform 0.25s;
  display: flex;
  flex-direction: column;
}
.pc-rel-card:hover {
  box-shadow: 0 6px 24px rgba(0,0,0,0.13);
  transform: translateY(-3px);
}
.pc-rel-img-wrap {
  position: relative;
  background: #f5f5f5;
  aspect-ratio: 1 / 1;
  overflow: hidden;
}
.pc-rel-img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.35s ease;
}
.pc-rel-card:hover .pc-rel-img-wrap img { transform: scale(1.06); }
.pc-rel-img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ccc;
}
.pc-rel-body {
  padding: 16px;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.pc-rel-vendor { font-size: 1.1rem; color: #999; text-transform: uppercase; letter-spacing: 0.07em; }
.pc-rel-title {
  font-size: 1.4rem;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.35;
  text-decoration: none;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.pc-rel-title:hover { color: {{ section.settings.accent_color }}; }
.pc-rel-price {
  font-size: 1.6rem;
  font-weight: 700;
  color: {{ section.settings.accent_color }};
  margin-top: auto;
}
.pc-rel-price-compare {
  font-size: 1.2rem;
  color: #aaa;
  text-decoration: line-through;
  margin-left: 6px;
  font-weight: 400;
}
.pc-rel-atc {
  display: block;
  width: 100%;
  padding: 10px;
  background: {{ section.settings.accent_color }};
  color: #fff;
  font-size: 1.3rem;
  font-weight: 600;
  text-align: center;
  border: none;
  border-radius: 6px;
  cursor: pointer;
  text-decoration: none;
  transition: opacity 0.2s;
  margin-top: 10px;
}
.pc-rel-atc:hover { opacity: 0.85; color: #fff; }

/* --- Loading State ---------------------------------------- */
.pc-product-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 300px;
  font-size: 1.4rem;
  color: #888;
}
{%- endstyle -%}

{%- assign product_form_id = 'pc-product-form-' | append: section.id -%}
{%- assign first_3d_model = product.media | where: 'media_type', 'model' | first -%}

<!-- ============================================================
     1. BREADCRUMB BANNER
     ============================================================ -->
<div class="pc-breadcrumb-banner">
  <div class="pc-breadcrumb-inner">
    <nav class="pc-breadcrumb-nav" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      <span class="pc-breadcrumb-sep" aria-hidden="true">&#8250;</span>
      {%- if collection -%}
        <a href="{{ collection.url }}">{{ collection.title }}</a>
        <span class="pc-breadcrumb-sep" aria-hidden="true">&#8250;</span>
      {%- elsif product.collections.size > 0 -%}
        <a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a>
        <span class="pc-breadcrumb-sep" aria-hidden="true">&#8250;</span>
      {%- endif -%}
      <span class="pc-breadcrumb-current" aria-current="page">{{ product.title | escape | truncate: 60 }}</span>
    </nav>
    <h1 class="pc-breadcrumb-title">{{ product.title | escape | truncate: 70 }}</h1>
  </div>
</div>

<!-- ============================================================
     2. PRODUCT SECTION — Gallery (6col) + Info (6col)
     ============================================================ -->
<div class="pc-product-section">
  <product-info
    id="ProductInfo-{{ section.id }}"
    data-section="{{ section.id }}"
    data-url="{{ product.url }}"
    class="pc-product-grid"
  >
    {%- assign product_form_id = 'pc-product-form-' | append: section.id -%}

    <!-- LEFT: Image Gallery -->
    <div class="pc-gallery-col">
      {%- if product.media.size > 0 -%}
        {%- assign featured = product.featured_media -%}
        <div class="pc-gallery-main" id="pc-main-img-wrap-{{ section.id }}">
          {%- if featured.media_type == 'image' or featured.media_type == nil -%}
            <img
              id="pc-main-img-{{ section.id }}"
              src="{{ featured | image_url: width: 900 }}"
              alt="{{ featured.alt | default: product.title | escape }}"
              width="{{ featured.width }}"
              height="{{ featured.height }}"
              loading="eager"
            >
          {%- else -%}
            <img
              id="pc-main-img-{{ section.id }}"
              src="{{ product.featured_image | image_url: width: 900 }}"
              alt="{{ product.title | escape }}"
              loading="eager"
            >
          {%- endif -%}

          {%- assign first_variant = product.selected_or_first_available_variant -%}
          {%- if first_variant.compare_at_price > first_variant.price -%}
            {%- assign saving_pct = first_variant.compare_at_price | minus: first_variant.price | times: 100 | divided_by: first_variant.compare_at_price -%}
            <span class="pc-gallery-badge">-{{ saving_pct }}%</span>
          {%- endif -%}
        </div>

        {%- if product.media.size > 1 -%}
          <div class="pc-gallery-thumbs" role="list">
            {%- for media in product.media limit: 10 -%}
              {%- assign thumb_src = media | image_url: width: 180 -%}
              {%- if media.media_type != 'image' -%}
                {%- assign thumb_src = media.preview_image | image_url: width: 180 -%}
              {%- endif -%}
              <button
                class="{% if forloop.first %}active{% endif %}"
                data-src="{{ media | image_url: width: 900 }}"
                data-main-id="pc-main-img-{{ section.id }}"
                aria-label="{{ media.alt | default: product.title | escape }}"
                role="listitem"
                onclick="pcSwitchImage(this)"
                type="button"
              >
                <img src="{{ thumb_src }}" alt="{{ media.alt | default: product.title | escape }}" loading="lazy" width="180" height="180">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      {%- else -%}
        <div class="pc-gallery-main" style="display:flex;align-items:center;justify-content:center;">
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {%- endif -%}
    </div><!-- /gallery col -->

    <!-- RIGHT: Product Info -->
    <div class="pc-info-col">
      {%- if product.vendor != blank -%}
        <p class="pc-product-vendor">{{ product.vendor }}</p>
      {%- endif -%}

      <h2 class="pc-product-title">{{ product.title | escape }}</h2>

      <!-- Rating row -->
      {%- if product.metafields.reviews.rating.value != blank -%}
        <div class="pc-product-rating-row">
          <div class="pc-stars" aria-hidden="true">
            {%- assign rating_val = product.metafields.reviews.rating.value.rating | round -%}
            {%- for i in (1..5) -%}
              {%- if i <= rating_val -%}&#9733;{%- else -%}&#9734;{%- endif -%}
            {%- endfor -%}
          </div>
          <span class="pc-review-count">
            {{ product.metafields.reviews.rating.value }} / {{ product.metafields.reviews.rating.value.scale_max }}
            {%- if product.metafields.reviews.rating_count -%}
              &nbsp;({{ product.metafields.reviews.rating_count }} {{ 'accessibility.total_reviews' | t }})
            {%- endif -%}
          </span>
        </div>
      {%- endif -%}

      <!-- Price Block -->
      <div class="pc-price-block" id="price-{{ section.id }}" role="status">
        {%- assign current_variant = product.selected_or_first_available_variant -%}
        <span class="pc-price-current">
          {%- if settings.currency_code_enabled -%}
            {{ current_variant.price | money_with_currency }}
          {%- else -%}
            {{ current_variant.price | money }}
          {%- endif -%}
        </span>
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <span class="pc-price-compare">
            {%- if settings.currency_code_enabled -%}
              {{ current_variant.compare_at_price | money_with_currency }}
            {%- else -%}
              {{ current_variant.compare_at_price | money }}
            {%- endif -%}
          </span>
          {%- assign savings = current_variant.compare_at_price | minus: current_variant.price -%}
          <span class="pc-price-saving">
            Save
            {%- if settings.currency_code_enabled -%}
              {{ savings | money_with_currency }}
            {%- else -%}
              {{ savings | money }}
            {%- endif -%}
          </span>
        {%- endif -%}
      </div>

      {%- if shop.taxes_included or shop.shipping_policy.body != blank -%}
        <p class="pc-product-meta" style="margin-top:-10px;margin-bottom:12px;">
          {%- if shop.taxes_included -%}
            <span>{{ 'products.product.include_taxes' | t }}</span>
          {%- endif -%}
          {%- if shop.shipping_policy.body != blank -%}
            <span>{{ 'products.product.shipping_policy_html' | t: link: shop.shipping_policy.url }}</span>
          {%- endif -%}
        </p>
      {%- endif -%}

      <div class="pc-divider"></div>

      <!-- Variant Picker -->
      {%- unless product.has_only_default_variant -%}
        {%- for option in product.options_with_values -%}
          <p class="pc-variant-label">{{ option.name }}:
            <strong>{{ option.selected_value }}</strong>
          </p>
          <div class="pc-variant-options">
            {%- for value in option.values -%}
              {%- assign variant_option = 'option' | append: forloop.parentloop.index -%}
              {%- assign current_variant_value = product.selected_or_first_available_variant[variant_option] -%}
              {%- assign is_selected = false -%}
              {%- if value == current_variant_value -%}
                {%- assign is_selected = true -%}
              {%- endif -%}
              <button
                type="button"
                class="variant-btn"
                data-option-index="{{ forloop.parentloop.index0 }}"
                data-option-value="{{ value | escape }}"
                aria-label="{{ option.name }}: {{ value }}"
                style="
                  padding: 8px 18px;
                  border: 2px solid {% if is_selected %}{{ section.settings.accent_color }}{% else %}#ddd{% endif %};
                  border-radius: 6px;
                  background: {% if is_selected %}{{ section.settings.accent_color }}{% else %}#fff{% endif %};
                  color: {% if is_selected %}#fff{% else %}#333{% endif %};
                  font-size: 1.3rem;
                  font-weight: 600;
                  cursor: pointer;
                  transition: all 0.2s;
                "
              >
                {{ value }}
              </button>
            {%- endfor -%}
          </div>
        {%- endfor -%}
        <div class="pc-divider"></div>
      {%- endunless -%}

      <!-- Quantity -->
      <div class="pc-qty-row">
        <span class="pc-qty-label">Qty:</span>
        <div class="pc-qty-input">
          <button class="pc-qty-btn" type="button" onclick="pcQtyChange(this,-1,'pc-qty-{{ section.id }}')" aria-label="Decrease quantity">&minus;</button>
          <input
            id="pc-qty-{{ section.id }}"
            class="pc-qty-number"
            type="number"
            name="quantity"
            value="1"
            min="1"
            form="{{ product_form_id }}"
            aria-label="Quantity"
          >
          <button class="pc-qty-btn" type="button" onclick="pcQtyChange(this,1,'pc-qty-{{ section.id }}')" aria-label="Increase quantity">&#43;</button>
        </div>

        <!-- Stock Status -->
        {%- if product.selected_or_first_available_variant.available -%}
          <span class="pc-stock-badge in-stock">
            <span class="pc-stock-dot"></span> In Stock
          </span>
        {%- else -%}
          <span class="pc-stock-badge out-stock">
            <span class="pc-stock-dot"></span> Out of Stock
          </span>
        {%- endif -%}
      </div>

      <!-- Add to Cart & Buy Now -->
      <product-form class="product-form" data-hide-errors="false">
        <div class="product-form__error-message-wrapper" role="alert" hidden>
          <span class="product-form__error-message"></span>
        </div>
        {%- form 'product', product,
          id: product_form_id,
          class: 'form',
          novalidate: 'novalidate',
          data-type: 'add-to-cart-form'
        -%}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" disabled class="product-variant-id">

          <div class="pc-btn-group">
            <button
              type="submit"
              name="add"
              class="pc-btn-atc"
              {%- if product.selected_or_first_available_variant.available == false -%}disabled{%- endif -%}
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
                <line x1="3" y1="6" x2="21" y2="6" stroke="white" stroke-width="2" fill="none"/>
                <path d="M16 10a4 4 0 01-8 0" stroke="white" stroke-width="2" fill="none"/>
              </svg>
              {%- if product.selected_or_first_available_variant.available -%}
                Add to Cart
              {%- else -%}
                Sold Out
              {%- endif -%}
            </button>

            {%- if section.settings.show_buy_now and product.selected_or_first_available_variant.available -%}
              {{ form | payment_button }}
            {%- endif -%}
          </div>

          {%- if section.settings.show_buy_now == false or product.selected_or_first_available_variant.available == false -%}
            <div class="pc-btn-group">
              <a href="{{ product.url }}" class="pc-btn-buy">View Full Details</a>
            </div>
          {%- endif -%}
        {%- endform -%}
      </product-form>

      <!-- Product Meta -->
      <div class="pc-divider"></div>
      <div class="pc-product-meta">
        {%- if product.selected_or_first_available_variant.sku != blank -%}
          <span><b>SKU:</b> {{ product.selected_or_first_available_variant.sku }}</span>
        {%- endif -%}
        {%- if product.type != blank -%}
          <span><b>Category:</b> {{ product.type }}</span>
        {%- endif -%}
        {%- if product.vendor != blank -%}
          <span><b>Brand:</b> {{ product.vendor }}</span>
        {%- endif -%}
        {%- if product.tags.size > 0 -%}
          <span><b>Tags:</b>
            {%- for tag in product.tags limit: 5 -%}
              <a href="{{ routes.collections_url }}/all/{{ tag | handleize }}" style="color:{{ section.settings.accent_color }};margin-right:4px;">{{ tag }}</a>
            {%- endfor -%}
          </span>
        {%- endif -%}
      </div>

    </div><!-- /info col -->
  </product-info>
</div><!-- /product section -->

<!-- ============================================================
     3. TABS — Description | Reviews | Additional Info
     ============================================================ -->
<div class="pc-tabs-section">
  <div class="pc-tabs-nav" role="tablist">
    <button
      class="pc-tab-btn active"
      role="tab"
      aria-selected="true"
      aria-controls="pc-tab-desc-{{ section.id }}"
      onclick="pcSwitchTab(this,'pc-tabs-{{ section.id }}')"
      type="button"
    >Description</button>
    <button
      class="pc-tab-btn"
      role="tab"
      aria-selected="false"
      aria-controls="pc-tab-reviews-{{ section.id }}"
      onclick="pcSwitchTab(this,'pc-tabs-{{ section.id }}')"
      type="button"
    >Reviews</button>
    <button
      class="pc-tab-btn"
      role="tab"
      aria-selected="false"
      aria-controls="pc-tab-info-{{ section.id }}"
      onclick="pcSwitchTab(this,'pc-tabs-{{ section.id }}')"
      type="button"
    >Shipping &amp; Info</button>
  </div>

  <div id="pc-tabs-{{ section.id }}" class="pc-tab-panels">
    <!-- Description Tab -->
    <div
      id="pc-tab-desc-{{ section.id }}"
      class="pc-tab-panel active"
      role="tabpanel"
    >
      {%- if product.description != blank -%}
        <div class="rte">{{ product.description }}</div>
      {%- else -%}
        <p style="color:#888;text-align:center;padding:30px 0;">No description available for this product.</p>
      {%- endif -%}
    </div>

    <!-- Reviews Tab -->
    <div
      id="pc-tab-reviews-{{ section.id }}"
      class="pc-tab-panel"
      role="tabpanel"
    >
      {%- if product.metafields.reviews.rating.value != blank -%}
        <div class="pc-review-summary">
          <div>
            <div class="pc-review-avg-score">{{ product.metafields.reviews.rating.value.rating | round: 1 }}</div>
            <div class="pc-review-stars-large">
              {%- assign rating_val = product.metafields.reviews.rating.value.rating | round -%}
              {%- for i in (1..5) -%}
                {%- if i <= rating_val -%}&#9733;{%- else -%}&#9734;{%- endif -%}
              {%- endfor -%}
            </div>
            <div class="pc-review-count-label">
              {%- if product.metafields.reviews.rating_count -%}
                Based on {{ product.metafields.reviews.rating_count }} {{ 'accessibility.total_reviews' | t }}
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- else -%}
        <div class="pc-reviews-empty">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
          </svg>
          <p>No reviews yet. Be the first to review this product!</p>
          <a href="#" class="pc-write-review-btn">Write a Review</a>
        </div>
      {%- endif -%}
    </div>

    <!-- Shipping & Info Tab -->
    <div
      id="pc-tab-info-{{ section.id }}"
      class="pc-tab-panel"
      role="tabpanel"
    >
      <div class="pc-info-grid">
        <div class="pc-info-card">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"/>
          </svg>
          <h4>Free Shipping</h4>
          <p>Free standard shipping on orders over $50. Express options available at checkout.</p>
        </div>
        <div class="pc-info-card">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99"/>
          </svg>
          <h4>Easy Returns</h4>
          <p>30-day hassle-free return policy. Items must be in original, unused condition.</p>
        </div>
        <div class="pc-info-card">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/>
          </svg>
          <h4>Secure Payment</h4>
          <p>All transactions are encrypted and processed securely. We accept major cards &amp; PayPal.</p>
        </div>
        <div class="pc-info-card">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155"/>
          </svg>
          <h4>24/7 Support</h4>
          <p>Our customer support team is available around the clock to answer your questions.</p>
        </div>
      </div>

      {%- if section.settings.additional_info_content != blank -%}
        <div class="rte" style="margin-top:24px;">{{ section.settings.additional_info_content }}</div>
      {%- endif -%}
    </div>
  </div>
</div><!-- /tabs section -->

<!-- ============================================================
     4. RELATED PRODUCTS — 4 cards
     ============================================================ -->
<div class="pc-related-section">
  <div class="pc-related-inner">
    <h2 class="pc-related-heading">
      <span>{{ section.settings.related_heading | default: 'You May Also Like' }}</span>
    </h2>

    <product-recommendations
      data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit=4"
      data-section="{{ section.id }}"
    >
      {%- if recommendations.performed and recommendations.products_count > 0 -%}
        <div class="pc-related-grid">
          {%- for rec in recommendations.products -%}
            <div class="pc-rel-card">
              <a href="{{ rec.url }}" class="pc-rel-img-wrap" tabindex="-1">
                {%- if rec.featured_image -%}
                  <img
                    src="{{ rec.featured_image | image_url: width: 400 }}"
                    alt="{{ rec.featured_image.alt | default: rec.title | escape }}"
                    loading="lazy"
                    width="400"
                    height="400"
                  >
                {%- else -%}
                  <div class="pc-rel-img-placeholder">
                    {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  </div>
                {%- endif -%}
              </a>
              <div class="pc-rel-body">
                {%- if rec.vendor != blank -%}
                  <span class="pc-rel-vendor">{{ rec.vendor }}</span>
                {%- endif -%}
                <a href="{{ rec.url }}" class="pc-rel-title">{{ rec.title | escape }}</a>
                <div>
                  <span class="pc-rel-price">
                    {%- if settings.currency_code_enabled -%}
                      {{ rec.price | money_with_currency }}
                    {%- else -%}
                      {{ rec.price | money }}
                    {%- endif -%}
                  </span>
                  {%- if rec.compare_at_price > rec.price -%}
                    <span class="pc-rel-price-compare">
                      {%- if settings.currency_code_enabled -%}
                        {{ rec.compare_at_price | money_with_currency }}
                      {%- else -%}
                        {{ rec.compare_at_price | money }}
                      {%- endif -%}
                    </span>
                  {%- endif -%}
                </div>
                <a href="{{ rec.url }}" class="pc-rel-atc">View Product</a>
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- else -%}
        <!-- Fallback: show collection products if recommendations not loaded yet -->
        {%- if product.collections.size > 0 -%}
          {%- assign fallback_collection = product.collections.first -%}
          <div class="pc-related-grid">
            {%- for fp in fallback_collection.products limit: 4 -%}
              {%- unless fp.id == product.id -%}
                <div class="pc-rel-card">
                  <a href="{{ fp.url }}" class="pc-rel-img-wrap" tabindex="-1">
                    {%- if fp.featured_image -%}
                      <img
                        src="{{ fp.featured_image | image_url: width: 400 }}"
                        alt="{{ fp.featured_image.alt | default: fp.title | escape }}"
                        loading="lazy"
                        width="400"
                        height="400"
                      >
                    {%- else -%}
                      <div class="pc-rel-img-placeholder">
                        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                      </div>
                    {%- endif -%}
                  </a>
                  <div class="pc-rel-body">
                    {%- if fp.vendor != blank -%}
                      <span class="pc-rel-vendor">{{ fp.vendor }}</span>
                    {%- endif -%}
                    <a href="{{ fp.url }}" class="pc-rel-title">{{ fp.title | escape }}</a>
                    <div>
                      <span class="pc-rel-price">{{ fp.price | money }}</span>
                      {%- if fp.compare_at_price > fp.price -%}
                        <span class="pc-rel-price-compare">{{ fp.compare_at_price | money }}</span>
                      {%- endif -%}
                    </div>
                    <a href="{{ fp.url }}" class="pc-rel-atc">View Product</a>
                  </div>
                </div>
              {%- endunless -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      {%- endif -%}
    </product-recommendations>
  </div>
</div><!-- /related section -->

<!-- ============================================================
     Scripts
     ============================================================ -->
<script>
  /* ---- Gallery thumbnail switcher ---- */
  function pcSwitchImage(btn) {
    var mainId = btn.getAttribute('data-main-id');
    var newSrc = btn.getAttribute('data-src');
    var mainImg = document.getElementById(mainId);
    if (mainImg) {
      mainImg.style.opacity = '0';
      mainImg.src = newSrc;
      mainImg.onload = function () { mainImg.style.opacity = '1'; };
      mainImg.style.transition = 'opacity 0.2s';
    }
    var allBtns = btn.closest('.pc-gallery-thumbs').querySelectorAll('button');
    allBtns.forEach(function(b) { b.classList.remove('active'); });
    btn.classList.add('active');
  }

  /* ---- Quantity +/- ---- */
  function pcQtyChange(btn, delta, inputId) {
    var inp = document.getElementById(inputId);
    if (!inp) return;
    var val = parseInt(inp.value, 10) || 1;
    val = Math.max(parseInt(inp.min, 10) || 1, val + delta);
    if (inp.max && val > parseInt(inp.max, 10)) val = parseInt(inp.max, 10);
    inp.value = val;
  }

  /* ---- Tab switcher ---- */
  function pcSwitchTab(btn, containerId) {
    var container = document.getElementById(containerId);
    if (!container) return;
    var tabsNav = btn.closest('.pc-tabs-nav');
    var allBtns = tabsNav.querySelectorAll('.pc-tab-btn');
    var allPanels = container.querySelectorAll('.pc-tab-panel');

    allBtns.forEach(function(b) {
      b.classList.remove('active');
      b.setAttribute('aria-selected', 'false');
    });
    allPanels.forEach(function(p) { p.classList.remove('active'); });

    btn.classList.add('active');
    btn.setAttribute('aria-selected', 'true');

    var targetId = btn.getAttribute('aria-controls');
    var targetPanel = document.getElementById(targetId);
    if (targetPanel) targetPanel.classList.add('active');
  }

  /* ---- Variant button selection ---- */
  document.querySelectorAll('.variant-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var idx = btn.getAttribute('data-option-index');
      var siblings = document.querySelectorAll('.variant-btn[data-option-index="' + idx + '"]');
      var accentColor = '{{ section.settings.accent_color }}';
      siblings.forEach(function(s) {
        s.style.borderColor = '#ddd';
        s.style.background = '#fff';
        s.style.color = '#333';
      });
      btn.style.borderColor = accentColor;
      btn.style.background = accentColor;
      btn.style.color = '#fff';
    });
  });
</script>

{%- if first_3d_model -%}
  <script type="application/json" id="ProductJSON-{{ product.id }}">
    {{ product.media | where: 'media_type', 'model' | json }}
  </script>
  <script src="{{ 'product-model.js' | asset_url }}" defer></script>
{%- endif -%}

<!-- Structured Data -->
<script type="application/ld+json">
{
  "@context": "http://schema.org/",
  "@type": "Product",
  "name": {{ product.title | json }},
  "url": {{ request.origin | append: product.url | json }},
  {%- if product.featured_image -%}
  "image": [{{ product.featured_image | image_url: width: 1200 | prepend: 'https:' | json }}],
  {%- endif -%}
  "description": {{ product.description | strip_html | truncate: 500 | json }},
  "sku": {{ product.selected_or_first_available_variant.sku | json }},
  "brand": {
    "@type": "Brand",
    "name": {{ product.vendor | json }}
  },
  "offers": {
    "@type": "Offer",
    "priceCurrency": {{ cart.currency.iso_code | json }},
    "price": {{ product.selected_or_first_available_variant.price | divided_by: 100.0 | json }},
    "availability": "http://schema.org/{% if product.selected_or_first_available_variant.available %}InStock{% else %}OutOfStock{% endif %}",
    "url": {{ request.origin | append: product.url | json }}
  }
}
</script>

{% schema %}
{
  "name": "PC Product Page",
  "tag": "article",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Breadcrumb Banner"
    },
    {
      "type": "color",
      "id": "breadcrumb_bg_color",
      "label": "Banner Background Color",
      "default": "#f0f4f8"
    },
    {
      "type": "color",
      "id": "breadcrumb_text_color",
      "label": "Banner Text Color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Colors & Buttons"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent / Button Color",
      "default": "#e63946"
    },
    {
      "type": "checkbox",
      "id": "show_buy_now",
      "label": "Show Buy It Now Button",
      "default": true
    },
    {
      "type": "header",
      "content": "Tabs"
    },
    {
      "type": "richtext",
      "id": "additional_info_content",
      "label": "Shipping & Info Tab — Extra Content"
    },
    {
      "type": "header",
      "content": "Related Products"
    },
    {
      "type": "text",
      "id": "related_heading",
      "label": "Related Products Heading",
      "default": "You May Also Like"
    },
    {
      "type": "color",
      "id": "related_bg_color",
      "label": "Related Products Background",
      "default": "#f8f9fa"
    }
  ]
}
{% endschema %}
