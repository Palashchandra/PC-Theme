{%- style -%}
/* ============================================================
   PC PRODUCT PAGE — Theme-aligned custom styles
   Theme colors:
     Accent 1 (dark):  rgb(var(--color-base-accent-1))   = #121212
     Accent 2 (teal):  rgb(var(--color-base-accent-2))   = #45c0b6
     Background 1:     rgb(var(--color-base-background-1)) = #fafaf9
     Background 2:     rgb(var(--color-base-background-2)) = #6b6b6b
     Text:             rgb(var(--color-base-text))
     Button labels:    rgb(var(--color-base-solid-button-labels))
   ============================================================ */

/* --- Breadcrumb Banner ------------------------------------ */
.pc-breadcrumb-banner {
  background-color: {{ section.settings.breadcrumb_bg_color }};
  padding: 18px 0;
  border-bottom: 1px solid rgba(var(--color-base-text), 0.08);
}
.pc-breadcrumb-inner {
  max-width: {{ settings.page_width }}px;
  margin: 0 auto;
  padding: 0 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 10px;
}
.pc-breadcrumb-nav {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 1.3rem;
  color: {{ section.settings.breadcrumb_text_color }};
}
.pc-breadcrumb-nav a {
  color: {{ section.settings.breadcrumb_text_color }};
  text-decoration: none;
  opacity: 0.7;
  transition: opacity 0.2s;
}
.pc-breadcrumb-nav a:hover { opacity: 1; text-decoration: underline; }
.pc-breadcrumb-sep { opacity: 0.4; font-size: 1.1rem; }
.pc-breadcrumb-current { font-weight: 600; }
.pc-breadcrumb-title {
  font-size: 1.7rem;
  font-weight: 700;
  color: {{ section.settings.breadcrumb_text_color }};
  margin: 0;
  line-height: 1.3;
  max-width: 60%;
  text-align: right;
}
@media screen and (max-width: 749px) {
  .pc-breadcrumb-inner { flex-direction: column; align-items: flex-start; }
  .pc-breadcrumb-title { max-width: 100%; text-align: left; font-size: 1.5rem; }
}

/* --- Product Section -------------------------------------- */
.pc-product-section {
  max-width: {{ settings.page_width }}px;
  margin: 0 auto;
  padding: 40px 20px;
}
.pc-product-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
  align-items: start;
}
@media screen and (max-width: 989px) {
  .pc-product-grid { grid-template-columns: 1fr; gap: 28px; }
}

/* --- Gallery Col ------------------------------------------ */
.pc-gallery-main {
  position: relative;
  background: rgb(var(--color-base-background-1));
  border-radius: {{ settings.card_corner_radius }}px;
  overflow: hidden;
  aspect-ratio: 1 / 1;
}
.pc-gallery-main img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
  transition: opacity 0.2s;
}
.pc-gallery-badge {
  position: absolute;
  top: 12px;
  left: 12px;
  background: rgb(var(--color-base-accent-2));
  color: rgb(var(--color-base-solid-button-labels));
  font-size: 1.1rem;
  font-weight: 700;
  padding: 4px 10px;
  border-radius: {{ settings.buttons_radius }}px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.pc-gallery-thumbs {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: {{ settings.spacing_grid_horizontal }}px;
  margin-top: 10px;
}
.pc-gallery-thumbs button {
  border: 2px solid transparent;
  border-radius: {{ settings.card_corner_radius }}px;
  padding: 0;
  cursor: pointer;
  background: rgb(var(--color-base-background-1));
  overflow: hidden;
  aspect-ratio: 1 / 1;
  transition: border-color 0.2s;
}
.pc-gallery-thumbs button.active,
.pc-gallery-thumbs button:hover {
  border-color: rgb(var(--color-base-accent-2));
}
.pc-gallery-thumbs button img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* --- Info Col --------------------------------------------- */
.pc-product-vendor {
  font-size: 1.2rem;
  color: rgb(var(--color-base-text), 0.55);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 8px;
}
.pc-product-title {
  font-size: clamp(2rem, 2.8vw, 3rem);
  font-weight: 700;
  line-height: 1.2;
  margin: 0 0 14px;
  color: rgb(var(--color-base-text));
  font-family: var(--font-heading-family);
}
.pc-rating-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 16px;
}
.pc-stars { color: rgb(var(--color-base-accent-2)); font-size: 1.5rem; letter-spacing: 1px; }
.pc-rating-count { font-size: 1.2rem; color: rgb(var(--color-base-text), 0.5); }

/* Price block */
.pc-price-block {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 12px;
  padding: 16px 20px;
  background: rgb(var(--color-base-background-1));
  border-radius: {{ settings.card_corner_radius }}px;
  margin-bottom: 22px;
  border-left: 4px solid rgb(var(--color-base-accent-2));
}
.pc-price-current {
  font-size: 3.2rem;
  font-weight: 700;
  color: rgb(var(--color-base-accent-2));
  line-height: 1;
  font-family: var(--font-heading-family);
}
.pc-price-compare {
  font-size: 1.8rem;
  color: rgba(var(--color-base-text), 0.35);
  text-decoration: line-through;
  line-height: 1;
}
.pc-price-saving {
  font-size: 1.2rem;
  background: rgba(var(--color-base-accent-2), 0.12);
  color: rgb(var(--color-base-accent-2));
  padding: 3px 9px;
  border-radius: 40px;
  font-weight: 600;
}
.pc-tax-info {
  font-size: 1.2rem;
  color: rgba(var(--color-base-text), 0.5);
  margin-top: -14px;
  margin-bottom: 18px;
}

/* Divider */
.pc-divider {
  height: 1px;
  background: rgba(var(--color-base-text), 0.08);
  margin: 20px 0;
}

/* Variants */
.pc-variant-label {
  font-size: 1.3rem;
  font-weight: 600;
  margin-bottom: 8px;
  color: rgb(var(--color-base-text));
  font-family: var(--font-body-family);
}
.pc-variant-options {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 18px;
}
.pc-variant-btn {
  padding: 8px 18px;
  border: 1px solid rgba(var(--color-base-outline-button-labels), 0.3);
  border-radius: {{ settings.variant_pills_radius }}px;
  background: transparent;
  color: rgb(var(--color-base-text));
  font-size: 1.3rem;
  font-weight: 600;
  cursor: pointer;
  transition: border-color 0.15s, background 0.15s, color 0.15s;
  font-family: var(--font-body-family);
}
.pc-variant-btn:hover {
  border-color: rgb(var(--color-base-accent-2));
  color: rgb(var(--color-base-accent-2));
}
.pc-variant-btn.is-active {
  border-color: rgb(var(--color-base-accent-2));
  background: rgb(var(--color-base-accent-2));
  color: rgb(var(--color-base-solid-button-labels));
}

/* Quantity */
.pc-qty-row {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 18px;
}
.pc-qty-label {
  font-size: 1.3rem;
  font-weight: 600;
  color: rgb(var(--color-base-text));
  min-width: 60px;
  font-family: var(--font-body-family);
}
.pc-qty-wrap {
  display: flex;
  align-items: center;
  border: 1px solid rgba(var(--color-base-text), {{ settings.inputs_border_opacity | divided_by: 100.0 }});
  border-radius: {{ settings.inputs_radius }}px;
  overflow: hidden;
}
.pc-qty-btn {
  width: 40px;
  height: 40px;
  background: rgb(var(--color-base-background-1));
  border: none;
  cursor: pointer;
  font-size: 1.8rem;
  color: rgb(var(--color-base-text));
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.15s;
  line-height: 1;
}
.pc-qty-btn:hover { background: rgba(var(--color-base-text), 0.06); }
.pc-qty-number {
  width: 52px;
  height: 40px;
  text-align: center;
  border: none;
  border-left: 1px solid rgba(var(--color-base-text), 0.1);
  border-right: 1px solid rgba(var(--color-base-text), 0.1);
  font-size: 1.4rem;
  font-weight: 600;
  color: rgb(var(--color-base-text));
  background: transparent;
  font-family: var(--font-body-family);
}
.pc-qty-number::-webkit-inner-spin-button,
.pc-qty-number::-webkit-outer-spin-button { -webkit-appearance: none; }
.pc-stock-in  { font-size: 1.2rem; color: #2a9d2a; font-weight: 600; display: flex; align-items: center; gap: 5px; }
.pc-stock-out { font-size: 1.2rem; color: #c00; font-weight: 600; display: flex; align-items: center; gap: 5px; }
.pc-stock-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; flex-shrink: 0; }
.pc-stock-in  .pc-stock-dot { background: #2a9d2a; }
.pc-stock-out .pc-stock-dot { background: #c00; }

/* Buttons */
.pc-btn-group { display: flex; flex-direction: column; gap: 10px; margin-bottom: 20px; }

.pc-btn-atc {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  width: 100%;
  padding: 16px 28px;
  background: rgb(var(--color-base-accent-1));
  color: rgb(var(--color-base-solid-button-labels));
  font-size: 1.5rem;
  font-weight: 700;
  border: {{ settings.buttons_border_thickness }}px solid rgb(var(--color-base-accent-1));
  border-radius: {{ settings.buttons_radius }}px;
  cursor: pointer;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  transition: opacity 0.2s;
  font-family: var(--font-body-family);
}
.pc-btn-atc:hover:not([disabled]) { opacity: 0.85; }
.pc-btn-atc[disabled] { opacity: 0.4; cursor: not-allowed; }
.pc-btn-atc svg { width: 18px; height: 18px; fill: currentColor; flex-shrink: 0; }

/* Product meta */
.pc-product-meta {
  display: flex;
  flex-direction: column;
  gap: 6px;
  font-size: 1.25rem;
  color: rgba(var(--color-base-text), 0.6);
  margin-top: 14px;
}
.pc-product-meta b { color: rgb(var(--color-base-text)); }
.pc-product-meta a {
  color: rgb(var(--color-base-accent-2));
  text-decoration: none;
}
.pc-product-meta a:hover { text-decoration: underline; }

/* ============================================================
   Tabs Section
   ============================================================ */
.pc-tabs-section {
  max-width: {{ settings.page_width }}px;
  margin: 0 auto 60px;
  padding: 0 20px;
}
.pc-tabs-nav {
  display: flex;
  border-bottom: 2px solid rgba(var(--color-base-text), 0.1);
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  gap: 0;
}
.pc-tab-btn {
  padding: 14px 30px;
  font-size: 1.4rem;
  font-weight: 600;
  color: rgba(var(--color-base-text), 0.5);
  background: none;
  border: none;
  border-bottom: 3px solid transparent;
  margin-bottom: -2px;
  cursor: pointer;
  white-space: nowrap;
  transition: color 0.2s, border-color 0.2s;
  font-family: var(--font-body-family);
  letter-spacing: 0.03em;
}
.pc-tab-btn:hover { color: rgb(var(--color-base-accent-2)); }
.pc-tab-btn.is-active {
  color: rgb(var(--color-base-accent-2));
  border-bottom-color: rgb(var(--color-base-accent-2));
}
.pc-tab-panels {
  border: 1px solid rgba(var(--color-base-text), 0.08);
  border-top: none;
  border-radius: 0 0 {{ settings.card_corner_radius }}px {{ settings.card_corner_radius }}px;
}
.pc-tab-panel {
  display: none;
  padding: 36px;
  font-size: 1.4rem;
  line-height: 1.8;
  color: rgb(var(--color-base-text));
  font-family: var(--font-body-family);
}
.pc-tab-panel.is-active { display: block; }
.pc-tab-panel .rte h2,
.pc-tab-panel .rte h3 { color: rgb(var(--color-base-text)); }
@media screen and (max-width: 749px) {
  .pc-tab-btn { padding: 12px 16px; font-size: 1.3rem; }
  .pc-tab-panel { padding: 24px 20px; }
}

/* Reviews panel */
.pc-reviews-empty {
  text-align: center;
  padding: 50px 20px;
  color: rgba(var(--color-base-text), 0.4);
}
.pc-reviews-empty svg { width: 48px; height: 48px; margin: 0 auto 14px; display: block; }
.pc-reviews-empty p { font-size: 1.4rem; margin-bottom: 18px; }
.pc-write-review-btn {
  display: inline-block;
  padding: 12px 28px;
  background: rgb(var(--color-base-accent-2));
  color: rgb(var(--color-base-solid-button-labels));
  font-size: 1.4rem;
  font-weight: 600;
  border-radius: {{ settings.buttons_radius }}px;
  text-decoration: none;
  transition: opacity 0.2s;
}
.pc-write-review-btn:hover { opacity: 0.85; color: rgb(var(--color-base-solid-button-labels)); }
.pc-review-summary {
  display: flex;
  align-items: center;
  gap: 24px;
  padding: 24px;
  background: rgb(var(--color-base-background-1));
  border-radius: {{ settings.card_corner_radius }}px;
  margin-bottom: 24px;
}
.pc-review-avg { font-size: 5rem; font-weight: 700; line-height: 1; color: rgb(var(--color-base-text)); }
.pc-review-stars-lg { font-size: 2rem; color: rgb(var(--color-base-accent-2)); margin: 6px 0; }
.pc-review-total { font-size: 1.2rem; color: rgba(var(--color-base-text), 0.5); }

/* Shipping info cards */
.pc-info-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 16px;
}
.pc-info-card {
  padding: 20px;
  background: rgb(var(--color-base-background-1));
  border-radius: {{ settings.card_corner_radius }}px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.pc-info-card svg {
  width: 26px;
  height: 26px;
  color: rgb(var(--color-base-accent-2));
  stroke: rgb(var(--color-base-accent-2));
  flex-shrink: 0;
}
.pc-info-card h4 { margin: 0; font-size: 1.4rem; color: rgb(var(--color-base-text)); }
.pc-info-card p  { margin: 0; font-size: 1.2rem; color: rgba(var(--color-base-text), 0.6); line-height: 1.55; }

/* ============================================================
   Related Products — grid wrapper only; cards use card-product snippet
   ============================================================ */
.pc-related-section {
  background: rgb(var(--color-base-background-1));
  padding: 56px 0;
  border-top: 1px solid rgba(var(--color-base-text), 0.06);
}
.pc-related-inner {
  max-width: {{ settings.page_width }}px;
  margin: 0 auto;
  padding: 0 20px;
}
.pc-related-heading {
  font-size: clamp(2rem, 2.5vw, 2.8rem);
  font-weight: 700;
  text-align: center;
  margin-bottom: 32px;
  color: rgb(var(--color-base-text));
  font-family: var(--font-heading-family);
}
.pc-related-heading span {
  display: inline-block;
  border-bottom: 3px solid rgb(var(--color-base-accent-2));
  padding-bottom: 6px;
}
.pc-related-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: {{ settings.spacing_grid_horizontal }}px;
}
@media screen and (max-width: 989px) {
  .pc-related-grid { grid-template-columns: repeat(2, 1fr); }
}
@media screen and (max-width: 480px) {
  .pc-related-grid { grid-template-columns: repeat(2, 1fr); }
}
{%- endstyle -%}

{%- assign product_form_id = 'pc-product-form-' | append: section.id -%}
{%- assign first_3d_model = product.media | where: 'media_type', 'model' | first -%}

<!-- ============================================================
     1. BREADCRUMB BANNER
     ============================================================ -->
<div class="pc-breadcrumb-banner">
  <div class="pc-breadcrumb-inner">
    <nav class="pc-breadcrumb-nav" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      <span class="pc-breadcrumb-sep" aria-hidden="true">&#8250;</span>
      {%- if collection -%}
        <a href="{{ collection.url }}">{{ collection.title }}</a>
        <span class="pc-breadcrumb-sep" aria-hidden="true">&#8250;</span>
      {%- elsif product.collections.size > 0 -%}
        <a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a>
        <span class="pc-breadcrumb-sep" aria-hidden="true">&#8250;</span>
      {%- endif -%}
      <span class="pc-breadcrumb-current" aria-current="page">{{ product.title | escape | truncate: 60 }}</span>
    </nav>
    <h1 class="pc-breadcrumb-title">{{ product.title | escape | truncate: 70 }}</h1>
  </div>
</div>

<!-- ============================================================
     2. PRODUCT — Gallery (6col) + Info (6col)
     ============================================================ -->
<div class="pc-product-section">
  <product-info
    id="ProductInfo-{{ section.id }}"
    data-section="{{ section.id }}"
    data-url="{{ product.url }}"
    class="pc-product-grid"
  >

    <!-- LEFT: Image Gallery -->
    <div class="pc-gallery-col">
      {%- if product.media.size > 0 -%}
        {%- assign featured = product.featured_media -%}
        <div class="pc-gallery-main">
          <img
            id="pc-main-img-{{ section.id }}"
            src="{{ featured | image_url: width: 900 }}"
            alt="{{ featured.alt | default: product.title | escape }}"
            width="{{ featured.width }}"
            height="{{ featured.height }}"
            loading="eager"
          >
          {%- assign cv = product.selected_or_first_available_variant -%}
          {%- if cv.compare_at_price > cv.price -%}
            {%- assign pct = cv.compare_at_price | minus: cv.price | times: 100 | divided_by: cv.compare_at_price -%}
            <span class="pc-gallery-badge">SAVE {{ pct }}%</span>
          {%- endif -%}
        </div>

        {%- if product.media.size > 1 -%}
          <div class="pc-gallery-thumbs" role="list">
            {%- for media in product.media limit: 10 -%}
              {%- assign thumb_src = media | image_url: width: 180 -%}
              {%- if media.media_type != 'image' -%}
                {%- assign thumb_src = media.preview_image | image_url: width: 180 -%}
              {%- endif -%}
              <button
                class="{% if forloop.first %}active{% endif %}"
                data-src="{{ media | image_url: width: 900 }}"
                data-main="pc-main-img-{{ section.id }}"
                aria-label="{{ media.alt | default: product.title | escape }}"
                role="listitem"
                type="button"
                onclick="pcSwitchImage(this)"
              >
                <img
                  src="{{ thumb_src }}"
                  alt="{{ media.alt | default: product.title | escape }}"
                  loading="lazy"
                  width="180"
                  height="180"
                >
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}

      {%- else -%}
        <div class="pc-gallery-main" style="display:flex;align-items:center;justify-content:center;">
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {%- endif -%}
    </div><!-- /gallery col -->

    <!-- RIGHT: Product Info -->
    <div class="pc-info-col">
      {%- if product.vendor != blank -%}
        <p class="pc-product-vendor">{{ product.vendor }}</p>
      {%- endif -%}

      <h2 class="pc-product-title">{{ product.title | escape }}</h2>

      <!-- Star rating (from metafields) -->
      {%- if product.metafields.reviews.rating.value != blank -%}
        <div class="pc-rating-row">
          <span class="pc-stars" aria-hidden="true">
            {%- assign rv = product.metafields.reviews.rating.value.rating | round -%}
            {%- for i in (1..5) -%}
              {%- if i <= rv -%}&#9733;{%- else -%}&#9734;{%- endif -%}
            {%- endfor -%}
          </span>
          <span class="pc-rating-count">
            {{ product.metafields.reviews.rating.value }} / {{ product.metafields.reviews.rating.value.scale_max }}
            {%- if product.metafields.reviews.rating_count -%}
              &nbsp;&bull;&nbsp;{{ product.metafields.reviews.rating_count }} {{ 'accessibility.total_reviews' | t }}
            {%- endif -%}
          </span>
        </div>
      {%- endif -%}

      <!-- Price -->
      {%- assign cv = product.selected_or_first_available_variant -%}
      <div class="pc-price-block" id="price-{{ section.id }}" role="status">
        <span class="pc-price-current">
          {%- if settings.currency_code_enabled -%}
            {{ cv.price | money_with_currency }}
          {%- else -%}
            {{ cv.price | money }}
          {%- endif -%}
        </span>
        {%- if cv.compare_at_price > cv.price -%}
          <span class="pc-price-compare">
            {%- if settings.currency_code_enabled -%}
              {{ cv.compare_at_price | money_with_currency }}
            {%- else -%}
              {{ cv.compare_at_price | money }}
            {%- endif -%}
          </span>
          {%- assign savings = cv.compare_at_price | minus: cv.price -%}
          <span class="pc-price-saving">
            Save
            {%- if settings.currency_code_enabled -%}
              {{ savings | money_with_currency }}
            {%- else -%}
              {{ savings | money }}
            {%- endif -%}
          </span>
        {%- endif -%}
      </div>

      {%- if shop.taxes_included or shop.shipping_policy.body != blank -%}
        <p class="pc-tax-info">
          {%- if shop.taxes_included -%}{{ 'products.product.include_taxes' | t }}{%- endif -%}
          {%- if shop.taxes_included and shop.shipping_policy.body != blank -%} &bull; {%- endif -%}
          {%- if shop.shipping_policy.body != blank -%}{{ 'products.product.shipping_policy_html' | t: link: shop.shipping_policy.url }}{%- endif -%}
        </p>
      {%- endif -%}

      <div class="pc-divider"></div>

      <!-- Variant Picker -->
      {%- unless product.has_only_default_variant -%}
        {%- for option in product.options_with_values -%}
          <p class="pc-variant-label">
            {{ option.name }}:&nbsp;<strong>{{ option.selected_value }}</strong>
          </p>
          <div class="pc-variant-options">
            {%- for value in option.values -%}
              {%- assign opt_key = 'option' | append: forloop.parentloop.index -%}
              {%- assign is_active = false -%}
              {%- if value == product.selected_or_first_available_variant[opt_key] -%}
                {%- assign is_active = true -%}
              {%- endif -%}
              <button
                type="button"
                class="pc-variant-btn{% if is_active %} is-active{% endif %}"
                data-option-index="{{ forloop.parentloop.index0 }}"
                data-option-value="{{ value | escape }}"
                aria-label="{{ option.name }}: {{ value }}"
              >{{ value }}</button>
            {%- endfor -%}
          </div>
        {%- endfor -%}
        <div class="pc-divider"></div>
      {%- endunless -%}

      <!-- Quantity + Stock -->
      <div class="pc-qty-row">
        <span class="pc-qty-label">Qty:</span>
        <div class="pc-qty-wrap">
          <button class="pc-qty-btn" type="button" onclick="pcQty(this,-1,'pc-qty-{{ section.id }}')" aria-label="Decrease">&minus;</button>
          <input
            id="pc-qty-{{ section.id }}"
            class="pc-qty-number"
            type="number"
            name="quantity"
            value="1"
            min="1"
            form="{{ product_form_id }}"
            aria-label="Quantity"
          >
          <button class="pc-qty-btn" type="button" onclick="pcQty(this,1,'pc-qty-{{ section.id }}')" aria-label="Increase">&#43;</button>
        </div>
        {%- if product.selected_or_first_available_variant.available -%}
          <span class="pc-stock-in"><span class="pc-stock-dot"></span>In Stock</span>
        {%- else -%}
          <span class="pc-stock-out"><span class="pc-stock-dot"></span>Out of Stock</span>
        {%- endif -%}
      </div>

      <!-- Add to Cart + Buy Now -->
      <product-form class="product-form" data-hide-errors="false">
        <div class="product-form__error-message-wrapper" role="alert" hidden>
          <span class="product-form__error-message"></span>
        </div>
        {%- form 'product', product,
          id: product_form_id,
          class: 'form',
          novalidate: 'novalidate',
          data-type: 'add-to-cart-form'
        -%}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" disabled class="product-variant-id">
          <div class="pc-btn-group">
            <button
              type="submit"
              name="add"
              class="pc-btn-atc"
              {%- unless product.selected_or_first_available_variant.available %} disabled{%- endunless -%}
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M6 2 3 6v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V6l-3-4H6zm0 0" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <line x1="3" y1="6" x2="21" y2="6" stroke="currentColor" stroke-width="1.5"/>
                <path d="M16 10a4 4 0 01-8 0" stroke="currentColor" stroke-width="1.5" fill="none"/>
              </svg>
              {%- if product.selected_or_first_available_variant.available -%}
                {{ 'products.product.add_to_cart' | t }}
              {%- else -%}
                {{ 'products.product.sold_out' | t }}
              {%- endif -%}
            </button>

            {%- if section.settings.show_buy_now and product.selected_or_first_available_variant.available -%}
              {{ form | payment_button }}
            {%- endif -%}
          </div>
        {%- endform -%}
      </product-form>

      <!-- Product meta -->
      <div class="pc-divider"></div>
      <div class="pc-product-meta">
        {%- if product.selected_or_first_available_variant.sku != blank -%}
          <span><b>SKU:</b> {{ product.selected_or_first_available_variant.sku }}</span>
        {%- endif -%}
        {%- if product.type != blank -%}
          <span><b>Category:</b> {{ product.type }}</span>
        {%- endif -%}
        {%- if product.vendor != blank -%}
          <span><b>Brand:</b> {{ product.vendor }}</span>
        {%- endif -%}
        {%- if product.tags.size > 0 -%}
          <span>
            <b>Tags:</b>
            {%- for tag in product.tags limit: 6 -%}
              <a href="{{ routes.collections_url }}/all/{{ tag | handleize }}">{{ tag }}</a>{% unless forloop.last %}, {% endunless %}
            {%- endfor -%}
          </span>
        {%- endif -%}
      </div>
    </div><!-- /info col -->

  </product-info>
</div><!-- /product section -->

<!-- ============================================================
     3. TABS — Description | Reviews | Shipping & Info
     ============================================================ -->
<div class="pc-tabs-section">
  <div class="pc-tabs-nav" role="tablist" id="pc-tablist-{{ section.id }}">
    <button
      class="pc-tab-btn is-active"
      role="tab"
      aria-selected="true"
      aria-controls="pc-tab-desc-{{ section.id }}"
      id="pc-tab-btn-desc-{{ section.id }}"
      type="button"
    >{{ 'products.product.description' | t }}</button>
    <button
      class="pc-tab-btn"
      role="tab"
      aria-selected="false"
      aria-controls="pc-tab-reviews-{{ section.id }}"
      id="pc-tab-btn-reviews-{{ section.id }}"
      type="button"
    >Reviews</button>
    <button
      class="pc-tab-btn"
      role="tab"
      aria-selected="false"
      aria-controls="pc-tab-info-{{ section.id }}"
      id="pc-tab-btn-info-{{ section.id }}"
      type="button"
    >Shipping &amp; Info</button>
  </div>

  <div class="pc-tab-panels">

    <!-- Description -->
    <div id="pc-tab-desc-{{ section.id }}" class="pc-tab-panel is-active" role="tabpanel" aria-labelledby="pc-tab-btn-desc-{{ section.id }}">
      {%- if product.description != blank -%}
        <div class="rte">{{ product.description }}</div>
      {%- else -%}
        <p style="color:rgba(var(--color-base-text),0.45);text-align:center;padding:30px 0;">
          No description available for this product.
        </p>
      {%- endif -%}
    </div>

    <!-- Reviews -->
    <div id="pc-tab-reviews-{{ section.id }}" class="pc-tab-panel" role="tabpanel" aria-labelledby="pc-tab-btn-reviews-{{ section.id }}">
      {%- if product.metafields.reviews.rating.value != blank -%}
        <div class="pc-review-summary">
          <div>
            <div class="pc-review-avg">{{ product.metafields.reviews.rating.value.rating | round: 1 }}</div>
            <div class="pc-review-stars-lg">
              {%- assign rv2 = product.metafields.reviews.rating.value.rating | round -%}
              {%- for i in (1..5) -%}
                {%- if i <= rv2 -%}&#9733;{%- else -%}&#9734;{%- endif -%}
              {%- endfor -%}
            </div>
            <div class="pc-review-total">
              {%- if product.metafields.reviews.rating_count -%}
                Based on {{ product.metafields.reviews.rating_count }} {{ 'accessibility.total_reviews' | t }}
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- else -%}
        <div class="pc-reviews-empty">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
          </svg>
          <p>No reviews yet. Be the first!</p>
          <a href="#" class="pc-write-review-btn">Write a Review</a>
        </div>
      {%- endif -%}
    </div>

    <!-- Shipping & Info -->
    <div id="pc-tab-info-{{ section.id }}" class="pc-tab-panel" role="tabpanel" aria-labelledby="pc-tab-btn-info-{{ section.id }}">
      <div class="pc-info-grid">
        <div class="pc-info-card">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"/>
          </svg>
          <h4>Free Shipping</h4>
          <p>Free standard shipping on orders over $50. Express options available at checkout.</p>
        </div>
        <div class="pc-info-card">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99"/>
          </svg>
          <h4>Easy Returns</h4>
          <p>30-day hassle-free returns. Items must be unused and in original condition.</p>
        </div>
        <div class="pc-info-card">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/>
          </svg>
          <h4>Secure Payment</h4>
          <p>All transactions are encrypted. We accept major credit cards, PayPal &amp; more.</p>
        </div>
        <div class="pc-info-card">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155"/>
          </svg>
          <h4>24/7 Support</h4>
          <p>Our team is always here to help with questions, orders, and product advice.</p>
        </div>
      </div>
      {%- if section.settings.additional_info_content != blank -%}
        <div class="rte" style="margin-top:28px;">{{ section.settings.additional_info_content }}</div>
      {%- endif -%}
    </div>

  </div>
</div><!-- /tabs -->

<!-- ============================================================
     4. RELATED PRODUCTS — 4 cards using theme's card-product snippet
     ============================================================ -->
<div class="pc-related-section">
  <div class="pc-related-inner">
    <h2 class="pc-related-heading">
      <span>{{ section.settings.related_heading | default: 'You May Also Like' }}</span>
    </h2>

    <product-recommendations
      data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit=4"
      data-section="{{ section.id }}"
    >
      {%- if recommendations.performed and recommendations.products_count > 0 -%}
        <div class="pc-related-grid">
          {%- for rec in recommendations.products -%}
            {% render 'collection-product-card',
              product_card: rec,
              button_label: section.settings.related_button_label,
              show_quick_add: section.settings.enable_quick_add,
              lazy_load: true,
              image_sizes: '(min-width: 990px) 25vw, (min-width: 750px) 50vw, 100vw',
              image_widths: '375, 550, 750, 900',
              image_width: 900,
              quick_add_source: 'pc-product-page'
            %}
          {%- endfor -%}
        </div>

      {%- elsif product.collections.size > 0 -%}
        {%- comment %} Fallback: same-collection products while recommendations load {%- endcomment %}
        {%- assign fb_coll = product.collections.first -%}
        {%- assign fb_count = 0 -%}
        <div class="pc-related-grid">
          {%- for fp in fb_coll.products -%}
            {%- unless fp.id == product.id or fb_count >= 4 -%}
              {%- assign fb_count = fb_count | plus: 1 -%}
              {% render 'collection-product-card',
                product_card: fp,
                button_label: section.settings.related_button_label,
                show_quick_add: section.settings.enable_quick_add,
                lazy_load: true,
                image_sizes: '(min-width: 990px) 25vw, (min-width: 750px) 50vw, 100vw',
                image_widths: '375, 550, 750, 900',
                image_width: 900,
                quick_add_source: 'pc-product-page'
              %}
            {%- endunless -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </product-recommendations>
  </div>
</div><!-- /related -->

<!-- ============================================================
     Scripts
     ============================================================ -->
<script>
  /* Gallery thumbnail switcher */
  function pcSwitchImage(btn) {
    var img = document.getElementById(btn.getAttribute('data-main'));
    if (!img) return;
    img.style.opacity = '0.5';
    img.src = btn.getAttribute('data-src');
    img.onload = function () { img.style.opacity = '1'; };
    btn.closest('.pc-gallery-thumbs').querySelectorAll('button').forEach(function (b) {
      b.classList.remove('active');
    });
    btn.classList.add('active');
  }

  /* Quantity +/- */
  function pcQty(btn, delta, id) {
    var inp = document.getElementById(id);
    if (!inp) return;
    var v = Math.max(parseInt(inp.min, 10) || 1, (parseInt(inp.value, 10) || 1) + delta);
    if (inp.max && v > parseInt(inp.max, 10)) v = parseInt(inp.max, 10);
    inp.value = v;
  }

  /* Tab switching */
  document.querySelectorAll('#pc-tablist-{{ section.id }} .pc-tab-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var panelId = btn.getAttribute('aria-controls');
      document.querySelectorAll('#pc-tablist-{{ section.id }} .pc-tab-btn').forEach(function (b) {
        b.classList.remove('is-active');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.add('is-active');
      btn.setAttribute('aria-selected', 'true');
      var panels = btn.closest('.pc-tabs-section').querySelectorAll('.pc-tab-panel');
      panels.forEach(function (p) { p.classList.remove('is-active'); });
      var target = document.getElementById(panelId);
      if (target) target.classList.add('is-active');
    });
  });

  /* Variant button active state */
  document.querySelectorAll('#ProductInfo-{{ section.id }} .pc-variant-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var idx = btn.getAttribute('data-option-index');
      document.querySelectorAll(
        '#ProductInfo-{{ section.id }} .pc-variant-btn[data-option-index="' + idx + '"]'
      ).forEach(function (b) { b.classList.remove('is-active'); });
      btn.classList.add('is-active');
    });
  });
</script>

{%- if first_3d_model -%}
  <script type="application/json" id="ProductJSON-{{ product.id }}">
    {{ product.media | where: 'media_type', 'model' | json }}
  </script>
  <script src="{{ 'product-model.js' | asset_url }}" defer></script>
{%- endif -%}

<script type="application/ld+json">
{
  "@context": "http://schema.org/",
  "@type": "Product",
  "name": {{ product.title | json }},
  "url": {{ request.origin | append: product.url | json }},
  {%- if product.featured_image -%}
  "image": [{{ product.featured_image | image_url: width: 1200 | prepend: 'https:' | json }}],
  {%- endif -%}
  "description": {{ product.description | strip_html | truncate: 500 | json }},
  "sku": {{ product.selected_or_first_available_variant.sku | json }},
  "brand": { "@type": "Brand", "name": {{ product.vendor | json }} },
  "offers": {
    "@type": "Offer",
    "priceCurrency": {{ cart.currency.iso_code | json }},
    "price": {{ product.selected_or_first_available_variant.price | divided_by: 100.0 | json }},
    "availability": "http://schema.org/{% if product.selected_or_first_available_variant.available %}InStock{% else %}OutOfStock{% endif %}",
    "url": {{ request.origin | append: product.url | json }}
  }
}
</script>

{% schema %}
{
  "name": "PC Product Page",
  "tag": "article",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Breadcrumb Banner"
    },
    {
      "type": "color",
      "id": "breadcrumb_bg_color",
      "label": "Banner Background",
      "default": "#f0f4f8"
    },
    {
      "type": "color",
      "id": "breadcrumb_text_color",
      "label": "Banner Text Color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "checkbox",
      "id": "show_buy_now",
      "label": "Show Buy It Now Button",
      "default": true
    },
    {
      "type": "header",
      "content": "Tabs"
    },
    {
      "type": "richtext",
      "id": "additional_info_content",
      "label": "Shipping & Info — Extra Content"
    },
    {
      "type": "header",
      "content": "Related Products"
    },
    {
      "type": "text",
      "id": "related_heading",
      "label": "Heading",
      "default": "You May Also Like"
    },
    {
      "type": "text",
      "id": "related_button_label",
      "label": "Card Button Label",
      "default": "Buy now"
    },
    {
      "type": "checkbox",
      "id": "enable_quick_add",
      "label": "Enable quick add button",
      "default": true
    }
  ]
}
{% endschema %}
