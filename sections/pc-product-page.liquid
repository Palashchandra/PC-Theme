<script src="{{ 'product-form.js' | asset_url }}" defer="defer" type="module"></script>

{%- style -%}
/* ============================================================
   PC PRODUCT PAGE — Gallery + Info
   Theme colors:
     Accent 1 (dark):  rgb(var(--color-base-accent-1))   = #121212
     Accent 2 (teal):  rgb(var(--color-base-accent-2))   = #45c0b6
     Background 1:     rgb(var(--color-base-background-1)) = #fafaf9
     Background 2:     rgb(var(--color-base-background-2)) = #6b6b6b
     Text:             rgb(var(--color-base-text))
     Button labels:    rgb(var(--color-base-solid-button-labels))
   ============================================================ */

/* --- Product Section -------------------------------------- */
.pc-product-section {
  max-width: {{ settings.page_width }}px;
  margin: 0 auto;
  padding: 40px 20px;
}
.pc-product-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
  align-items: start;
}
@media screen and (max-width: 989px) {
  .pc-product-grid { grid-template-columns: 1fr; gap: 28px; }
}

/* --- Gallery Col ------------------------------------------ */
.pc-gallery-main {
  position: relative;
  background: rgb(var(--color-base-background-1));
  border-radius: {{ settings.card_corner_radius }}px;
  overflow: hidden;
  aspect-ratio: 1 / 1;
}
.pc-gallery-main img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
  transition: opacity 0.2s;
}
.pc-gallery-badge {
  position: absolute;
  top: 12px;
  left: 12px;
  background: rgb(var(--color-base-accent-2));
  color: rgb(var(--color-base-solid-button-labels));
  font-size: 1.1rem;
  font-weight: 700;
  padding: 4px 10px;
  border-radius: {{ settings.buttons_radius }}px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.pc-gallery-thumbs {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: {{ settings.spacing_grid_horizontal }}px;
  margin-top: 10px;
}
.pc-gallery-thumbs button {
  border: 2px solid transparent;
  border-radius: {{ settings.card_corner_radius }}px;
  padding: 0;
  cursor: pointer;
  background: rgb(var(--color-base-background-1));
  overflow: hidden;
  aspect-ratio: 1 / 1;
  transition: border-color 0.2s;
}
.pc-gallery-thumbs button.active,
.pc-gallery-thumbs button:hover {
  border-color: rgb(var(--color-base-accent-2));
}
.pc-gallery-thumbs button img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* --- Info Col --------------------------------------------- */
.pc-product-vendor {
  font-size: 1.2rem;
  color: rgb(var(--color-base-text), 0.55);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 8px;
}
.pc-product-title {
  font-size: clamp(2rem, 2.8vw, 3rem);
  font-weight: 700;
  line-height: 1.2;
  margin: 0 0 14px;
  color: rgb(var(--color-base-text));
  font-family: var(--font-heading-family);
}
.pc-rating-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 16px;
}
.pc-stars { color: rgb(var(--color-base-accent-2)); font-size: 1.5rem; letter-spacing: 1px; }
.pc-rating-count { font-size: 1.2rem; color: rgb(var(--color-base-text), 0.5); }

/* Price block */
.pc-price-block {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 12px;
  padding: 16px 20px;
  background: rgb(var(--color-base-background-1));
  border-radius: {{ settings.card_corner_radius }}px;
  margin-bottom: 22px;
  border-left: 4px solid rgb(var(--color-base-accent-2));
}
.pc-price-current {
  font-size: 3.2rem;
  font-weight: 700;
  color: rgb(var(--color-base-accent-2));
  line-height: 1;
  font-family: var(--font-heading-family);
}
.pc-price-compare {
  font-size: 1.8rem;
  color: rgba(var(--color-base-text), 0.35);
  text-decoration: line-through;
  line-height: 1;
}
.pc-price-saving {
  font-size: 1.2rem;
  background: rgba(var(--color-base-accent-2), 0.12);
  color: rgb(var(--color-base-accent-2));
  padding: 3px 9px;
  border-radius: 40px;
  font-weight: 600;
}
.pc-tax-info {
  font-size: 1.2rem;
  color: rgba(var(--color-base-text), 0.5);
  margin-top: -14px;
  margin-bottom: 18px;
}

/* Divider */
.pc-divider {
  height: 1px;
  background: rgba(var(--color-base-text), 0.08);
  margin: 20px 0;
}

/* Variants */
.pc-variant-label {
  font-size: 1.3rem;
  font-weight: 600;
  margin-bottom: 8px;
  color: rgb(var(--color-base-text));
  font-family: var(--font-body-family);
}
.pc-variant-options {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 18px;
}
.pc-variant-btn {
  padding: 8px 18px;
  border: 1px solid rgba(var(--color-base-outline-button-labels), 0.3);
  border-radius: {{ settings.variant_pills_radius }}px;
  background: transparent;
  color: rgb(var(--color-base-text));
  font-size: 1.3rem;
  font-weight: 600;
  cursor: pointer;
  transition: border-color 0.15s, background 0.15s, color 0.15s;
  font-family: var(--font-body-family);
}
.pc-variant-btn:hover {
  border-color: rgb(var(--color-base-accent-2));
  color: rgb(var(--color-base-accent-2));
}
.pc-variant-btn.is-active {
  border-color: rgb(var(--color-base-accent-2));
  background: rgb(var(--color-base-accent-2));
  color: rgb(var(--color-base-solid-button-labels));
}

/* Quantity */
.pc-qty-row {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 18px;
}
.pc-qty-label {
  font-size: 1.3rem;
  font-weight: 600;
  color: rgb(var(--color-base-text));
  min-width: 60px;
  font-family: var(--font-body-family);
}
.pc-qty-wrap {
  display: flex;
  align-items: center;
  border: 1px solid rgba(var(--color-base-text), {{ settings.inputs_border_opacity | divided_by: 100.0 }});
  border-radius: {{ settings.inputs_radius }}px;
  overflow: hidden;
}
.pc-qty-btn {
  width: 40px;
  height: 40px;
  background: rgb(var(--color-base-background-1));
  border: none;
  cursor: pointer;
  font-size: 1.8rem;
  color: rgb(var(--color-base-text));
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.15s;
  line-height: 1;
}
.pc-qty-btn:hover { background: rgba(var(--color-base-text), 0.06); }
.pc-qty-number {
  width: 52px;
  height: 40px;
  text-align: center;
  border: none;
  border-left: 1px solid rgba(var(--color-base-text), 0.1);
  border-right: 1px solid rgba(var(--color-base-text), 0.1);
  font-size: 1.4rem;
  font-weight: 600;
  color: rgb(var(--color-base-text));
  background: transparent;
  font-family: var(--font-body-family);
}
.pc-qty-number::-webkit-inner-spin-button,
.pc-qty-number::-webkit-outer-spin-button { -webkit-appearance: none; }
.pc-stock-in  { font-size: 1.2rem; color: #2a9d2a; font-weight: 600; display: flex; align-items: center; gap: 5px; }
.pc-stock-out { font-size: 1.2rem; color: #c00; font-weight: 600; display: flex; align-items: center; gap: 5px; }
.pc-stock-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; flex-shrink: 0; }
.pc-stock-in  .pc-stock-dot { background: #2a9d2a; }
.pc-stock-out .pc-stock-dot { background: #c00; }

/* Buttons */
.pc-btn-group { display: flex; flex-direction: column; gap: 10px; margin-bottom: 20px; }

.pc-btn-atc {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  width: 100%;
  padding: 16px 28px;
  background: rgb(var(--color-base-accent-1));
  color: rgb(var(--color-base-solid-button-labels));
  font-size: 1.5rem;
  font-weight: 700;
  border: {{ settings.buttons_border_thickness }}px solid rgb(var(--color-base-accent-1));
  border-radius: {{ settings.buttons_radius }}px;
  cursor: pointer;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  transition: opacity 0.2s;
  font-family: var(--font-body-family);
}
.pc-btn-atc:hover:not([disabled]) { opacity: 0.85; }
.pc-btn-atc[disabled] { opacity: 0.4; cursor: not-allowed; }
.pc-btn-atc svg { width: 18px; height: 18px; fill: currentColor; flex-shrink: 0; }

/* Product meta */
.pc-product-meta {
  display: flex;
  flex-direction: column;
  gap: 6px;
  font-size: 1.25rem;
  color: rgba(var(--color-base-text), 0.6);
  margin-top: 14px;
}
.pc-product-meta b { color: rgb(var(--color-base-text)); }
.pc-product-meta a {
  color: rgb(var(--color-base-accent-2));
  text-decoration: none;
}
.pc-product-meta a:hover { text-decoration: underline; }

/* App blocks */
.pc-app-block { width: 100%; margin-top: 6px; }

/* Block: description (short, inside info col) */
.pc-block-description { font-size: 1.4rem; line-height: 1.75; color: rgba(var(--color-base-text), 0.8); }
.pc-block-description p:first-child { margin-top: 0; }
.pc-block-description p:last-child  { margin-bottom: 0; }

/* Block: text */
.pc-block-text { font-size: 1.4rem; line-height: 1.7; color: rgb(var(--color-base-text)); }
.pc-block-notice {
  padding: 12px 16px;
  background: rgba(var(--color-base-accent-2), 0.1);
  border-left: 3px solid rgb(var(--color-base-accent-2));
  border-radius: 0 {{ settings.card_corner_radius }}px {{ settings.card_corner_radius }}px 0;
  font-size: 1.3rem;
}
.pc-block-muted { color: rgba(var(--color-base-text), 0.5); font-size: 1.25rem; }

/* Block: custom liquid */
.pc-block-custom { font-size: 1.4rem; }
{%- endstyle -%}

{%- assign product_form_id = 'pc-product-form-' | append: section.id -%}
{%- assign first_3d_model = product.media | where: 'media_type', 'model' | first -%}

<div class="pc-product-section">
  <product-info
    id="ProductInfo-{{ section.id }}"
    data-section="{{ section.id }}"
    data-url="{{ product.url }}"
    class="pc-product-grid"
  >

    <!-- LEFT: Image Gallery -->
    <div class="pc-gallery-col">
      {%- if product.media.size > 0 -%}
        {%- assign featured = product.featured_media -%}
        <div class="pc-gallery-main">
          <img
            id="pc-main-img-{{ section.id }}"
            src="{{ featured | image_url: width: 900 }}"
            alt="{{ featured.alt | default: product.title | escape }}"
            width="{{ featured.width }}"
            height="{{ featured.height }}"
            loading="eager"
          >
          {%- assign cv = product.selected_or_first_available_variant -%}
          {%- if cv.compare_at_price > cv.price -%}
            {%- assign pct = cv.compare_at_price | minus: cv.price | times: 100 | divided_by: cv.compare_at_price -%}
            <span class="pc-gallery-badge">SAVE {{ pct }}%</span>
          {%- endif -%}
        </div>

        {%- if product.media.size > 1 -%}
          <div class="pc-gallery-thumbs" role="list">
            {%- for media in product.media limit: 10 -%}
              {%- assign thumb_src = media | image_url: width: 180 -%}
              {%- if media.media_type != 'image' -%}
                {%- assign thumb_src = media.preview_image | image_url: width: 180 -%}
              {%- endif -%}
              <button
                class="{% if forloop.first %}active{% endif %}"
                data-src="{{ media | image_url: width: 900 }}"
                data-main="pc-main-img-{{ section.id }}"
                aria-label="{{ media.alt | default: product.title | escape }}"
                role="listitem"
                type="button"
                onclick="pcSwitchImage(this)"
              >
                <img
                  src="{{ thumb_src }}"
                  alt="{{ media.alt | default: product.title | escape }}"
                  loading="lazy"
                  width="180"
                  height="180"
                >
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}

      {%- else -%}
        <div class="pc-gallery-main" style="display:flex;align-items:center;justify-content:center;">
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {%- endif -%}
    </div><!-- /gallery col -->

    <!-- RIGHT: Product Info — fully block-driven, drag & drop in theme editor -->
    <div class="pc-info-col">

      {%- for block in section.blocks -%}
        {%- case block.type -%}

          {%- when '@app' -%}
            <div class="pc-app-block" {{ block.shopify_attributes }}>
              {% render block %}
            </div>

          {%- when 'title' -%}
            <div {{ block.shopify_attributes }}>
              <h2 class="pc-product-title">{{ product.title | escape }}</h2>
            </div>

          {%- when 'vendor' -%}
            {%- if product.vendor != blank -%}
              <p class="pc-product-vendor" {{ block.shopify_attributes }}>{{ product.vendor }}</p>
            {%- endif -%}

          {%- when 'rating' -%}
            {%- if product.metafields.reviews.rating.value != blank -%}
              <div class="pc-rating-row" {{ block.shopify_attributes }}>
                <span class="pc-stars" aria-hidden="true">
                  {%- assign rv = product.metafields.reviews.rating.value.rating | round -%}
                  {%- for i in (1..5) -%}
                    {%- if i <= rv -%}&#9733;{%- else -%}&#9734;{%- endif -%}
                  {%- endfor -%}
                </span>
                <span class="pc-rating-count">
                  {{ product.metafields.reviews.rating.value }} / {{ product.metafields.reviews.rating.value.scale_max }}
                  {%- if product.metafields.reviews.rating_count -%}
                    &nbsp;&bull;&nbsp;{{ product.metafields.reviews.rating_count }} {{ 'accessibility.total_reviews' | t }}
                  {%- endif -%}
                </span>
              </div>
            {%- endif -%}

          {%- when 'price' -%}
            {%- assign cv = product.selected_or_first_available_variant -%}
            <div {{ block.shopify_attributes }}>
              <div class="pc-price-block" id="price-{{ section.id }}" role="status">
                <span class="pc-price-current">
                  {%- if settings.currency_code_enabled -%}
                    {{ cv.price | money_with_currency }}
                  {%- else -%}
                    {{ cv.price | money }}
                  {%- endif -%}
                </span>
                {%- if cv.compare_at_price > cv.price -%}
                  <span class="pc-price-compare">
                    {%- if settings.currency_code_enabled -%}
                      {{ cv.compare_at_price | money_with_currency }}
                    {%- else -%}
                      {{ cv.compare_at_price | money }}
                    {%- endif -%}
                  </span>
                  {%- assign savings = cv.compare_at_price | minus: cv.price -%}
                  <span class="pc-price-saving">
                    Save
                    {%- if settings.currency_code_enabled -%}
                      {{ savings | money_with_currency }}
                    {%- else -%}
                      {{ savings | money }}
                    {%- endif -%}
                  </span>
                {%- endif -%}
              </div>
              {%- if shop.taxes_included or shop.shipping_policy.body != blank -%}
                <p class="pc-tax-info">
                  {%- if shop.taxes_included -%}{{ 'products.product.include_taxes' | t }}{%- endif -%}
                  {%- if shop.taxes_included and shop.shipping_policy.body != blank -%} &bull; {%- endif -%}
                  {%- if shop.shipping_policy.body != blank -%}{{ 'products.product.shipping_policy_html' | t: link: shop.shipping_policy.url }}{%- endif -%}
                </p>
              {%- endif -%}
            </div>

          {%- when 'divider' -%}
            <div class="pc-divider" {{ block.shopify_attributes }}></div>

          {%- when 'variant_picker' -%}
            {%- unless product.has_only_default_variant -%}
              <div {{ block.shopify_attributes }}>
                {%- for option in product.options_with_values -%}
                  <p class="pc-variant-label" data-option-index="{{ forloop.index0 }}">
                    {{ option.name }}:&nbsp;<strong class="pc-variant-selected-val">{{ option.selected_value }}</strong>
                  </p>
                  <div class="pc-variant-options">
                    {%- for value in option.values -%}
                      {%- assign opt_key = 'option' | append: forloop.parentloop.index -%}
                      {%- assign is_active = false -%}
                      {%- if value == product.selected_or_first_available_variant[opt_key] -%}
                        {%- assign is_active = true -%}
                      {%- endif -%}
                      <button
                        type="button"
                        class="pc-variant-btn{% if is_active %} is-active{% endif %}"
                        data-option-index="{{ forloop.parentloop.index0 }}"
                        data-option-value="{{ value | escape }}"
                        aria-label="{{ option.name }}: {{ value }}"
                      >{{ value }}</button>
                    {%- endfor -%}
                  </div>
                {%- endfor -%}
              </div>
            {%- endunless -%}

          {%- when 'quantity_selector' -%}
            <div class="pc-qty-row" {{ block.shopify_attributes }}>
              <span class="pc-qty-label">{{ block.settings.label | default: 'Qty' }}:</span>
              <div class="pc-qty-wrap">
                <button class="pc-qty-btn" type="button" onclick="pcQty(this,-1,'pc-qty-{{ section.id }}')" aria-label="Decrease">&minus;</button>
                <input
                  id="pc-qty-{{ section.id }}"
                  class="pc-qty-number"
                  type="number"
                  name="quantity"
                  value="1"
                  min="1"
                  form="{{ product_form_id }}"
                  aria-label="Quantity"
                >
                <button class="pc-qty-btn" type="button" onclick="pcQty(this,1,'pc-qty-{{ section.id }}')" aria-label="Increase">&#43;</button>
              </div>
              {%- if block.settings.show_stock -%}
                {%- if product.selected_or_first_available_variant.available -%}
                  <span class="pc-stock-in"><span class="pc-stock-dot"></span>In Stock</span>
                {%- else -%}
                  <span class="pc-stock-out"><span class="pc-stock-dot"></span>Out of Stock</span>
                {%- endif -%}
              {%- endif -%}
            </div>

          {%- when 'buy_buttons' -%}
            <div {{ block.shopify_attributes }}>
              <product-form class="product-form" data-hide-errors="false">
                <div class="product-form__error-message-wrapper" role="alert" hidden>
                  <span class="product-form__error-message"></span>
                </div>
                {%- form 'product', product,
                  id: product_form_id,
                  class: 'form',
                  novalidate: 'novalidate',
                  data-type: 'add-to-cart-form'
                -%}
                  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" disabled class="product-variant-id">
                  <div class="pc-btn-group">
                    <button
                      type="submit"
                      name="add"
                      class="pc-btn-atc"
                      {%- unless product.selected_or_first_available_variant.available %} disabled{%- endunless -%}
                    >
                      <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M6 2 3 6v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V6l-3-4H6z" stroke="currentColor" stroke-width="1.5" fill="none"/>
                        <line x1="3" y1="6" x2="21" y2="6" stroke="currentColor" stroke-width="1.5"/>
                        <path d="M16 10a4 4 0 01-8 0" stroke="currentColor" stroke-width="1.5" fill="none"/>
                      </svg>
                      {%- if product.selected_or_first_available_variant.available -%}
                        {{ 'products.product.add_to_cart' | t }}
                      {%- else -%}
                        {{ 'products.product.sold_out' | t }}
                      {%- endif -%}
                    </button>
                    {%- if block.settings.show_dynamic_checkout and product.selected_or_first_available_variant.available -%}
                      {{ form | payment_button }}
                    {%- endif -%}
                  </div>
                  <div class="loading-overlay__spinner hidden" aria-hidden="true">
                    <svg aria-hidden="true" focusable="false" class="spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg">
                      <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                    </svg>
                  </div>
                {%- endform -%}
              </product-form>
            </div>

          {%- when 'description' -%}
            {%- if product.description != blank -%}
              <div class="pc-block-description rte" {{ block.shopify_attributes }}>
                {{ product.description }}
              </div>
            {%- endif -%}

          {%- when 'sku' -%}
            {%- if product.selected_or_first_available_variant.sku != blank -%}
              <p
                class="pc-product-meta"
                id="Sku-{{ section.id }}"
                role="status"
                {{ block.shopify_attributes }}
              >
                <span><b>SKU:</b> {{ product.selected_or_first_available_variant.sku }}</span>
              </p>
            {%- endif -%}

          {%- when 'product_meta' -%}
            <div class="pc-product-meta" {{ block.shopify_attributes }}>
              {%- if block.settings.show_sku and product.selected_or_first_available_variant.sku != blank -%}
                <span><b>SKU:</b> {{ product.selected_or_first_available_variant.sku }}</span>
              {%- endif -%}
              {%- if block.settings.show_type and product.type != blank -%}
                <span><b>Category:</b> {{ product.type }}</span>
              {%- endif -%}
              {%- if block.settings.show_vendor and product.vendor != blank -%}
                <span><b>Brand:</b> {{ product.vendor }}</span>
              {%- endif -%}
              {%- if block.settings.show_tags and product.tags.size > 0 -%}
                <span>
                  <b>Tags:</b>
                  {%- for tag in product.tags limit: 6 -%}
                    <a href="{{ routes.collections_url }}/all/{{ tag | handleize }}">{{ tag }}</a>{% unless forloop.last %}, {% endunless %}
                  {%- endfor -%}
                </span>
              {%- endif -%}
            </div>

          {%- when 'text' -%}
            {%- if block.settings.text != blank -%}
              <div
                class="pc-block-text{% if block.settings.style == 'notice' %} pc-block-notice{% elsif block.settings.style == 'muted' %} pc-block-muted{% endif %}"
                {{ block.shopify_attributes }}
              >
                {{ block.settings.text }}
              </div>
            {%- endif -%}

          {%- when 'custom_liquid' -%}
            <div class="pc-block-custom" {{ block.shopify_attributes }}>
              {{ block.settings.custom_liquid }}
            </div>

        {%- endcase -%}
      {%- endfor -%}

    </div><!-- /info col -->

  </product-info>
</div><!-- /product section -->

<script>
  /* Gallery thumbnail switcher */
  function pcSwitchImage(btn) {
    var img = document.getElementById(btn.getAttribute('data-main'));
    if (!img) return;
    img.style.opacity = '0.5';
    img.src = btn.getAttribute('data-src');
    img.onload = function () { img.style.opacity = '1'; };
    btn.closest('.pc-gallery-thumbs').querySelectorAll('button').forEach(function (b) {
      b.classList.remove('active');
    });
    btn.classList.add('active');
  }

  /* Quantity +/- */
  function pcQty(btn, delta, id) {
    var inp = document.getElementById(id);
    if (!inp) return;
    var v = Math.max(parseInt(inp.min, 10) || 1, (parseInt(inp.value, 10) || 1) + delta);
    if (inp.max && v > parseInt(inp.max, 10)) v = parseInt(inp.max, 10);
    inp.value = v;
  }

  /* Variant button active state + form variant ID update */
  var pcProductVariants = {{ product.variants | json }};

  function pcGetSelectedOptions() {
    var selected = [];
    document.querySelectorAll('#ProductInfo-{{ section.id }} .pc-variant-options').forEach(function (group) {
      var active = group.querySelector('.pc-variant-btn.is-active');
      if (active) selected.push(active.getAttribute('data-option-value'));
    });
    return selected;
  }

  function pcUpdateVariant() {
    var selectedOptions = pcGetSelectedOptions();
    var matched = null;
    for (var i = 0; i < pcProductVariants.length; i++) {
      var v = pcProductVariants[i];
      var opts = [v.option1, v.option2, v.option3].filter(function (o) { return o !== null && o !== undefined; });
      if (opts.length === selectedOptions.length && opts.every(function (o, idx) { return o === selectedOptions[idx]; })) {
        matched = v;
        break;
      }
    }
    if (!matched) return;

    /* Update hidden variant input */
    var variantInput = document.querySelector('#{{ product_form_id }} .product-variant-id');
    if (variantInput) variantInput.value = matched.id;

    /* Update submit button state */
    var submitBtn = document.querySelector('#{{ product_form_id }} [type="submit"]');
    if (submitBtn) {
      if (matched.available) {
        submitBtn.removeAttribute('disabled');
        submitBtn.textContent = {{ 'products.product.add_to_cart' | t | json }};
      } else {
        submitBtn.setAttribute('disabled', '');
        submitBtn.textContent = {{ 'products.product.sold_out' | t | json }};
      }
    }
  }

  document.querySelectorAll('#ProductInfo-{{ section.id }} .pc-variant-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var idx = btn.getAttribute('data-option-index');
      document.querySelectorAll(
        '#ProductInfo-{{ section.id }} .pc-variant-btn[data-option-index="' + idx + '"]'
      ).forEach(function (b) { b.classList.remove('is-active'); });
      btn.classList.add('is-active');

      /* Update the label's displayed selected value */
      var label = document.querySelector('#ProductInfo-{{ section.id }} .pc-variant-label[data-option-index="' + idx + '"] .pc-variant-selected-val');
      if (label) label.textContent = btn.getAttribute('data-option-value');

      pcUpdateVariant();
    });
  });

  /* ── Cart-drawer fix ────────────────────────────────────────────
     product-form.js looks up cart-drawer in its constructor, but
     because it is loaded as type="module" the CartDrawer custom
     element (loaded as a plain defer script from header.liquid) may
     not have upgraded yet, leaving this.cart = null and causing a
     redirect to /cart instead of opening the drawer.

     We also polyfill window.getCurrentSellingPlanId() here because
     selling-plans.js is only loaded by main-product.liquid, and its
     absence causes a TypeError that silently aborts the submit handler.
  ── ────────────────────────────────────────────────────────────── */
  (function () {
    /* 1. Polyfill so product-form.js line 39 never throws */
    if (!window.getCurrentSellingPlanId) {
      window.getCurrentSellingPlanId = function () {
        var el = document.querySelector('product-subscriptions');
        return el && el.getCurrentSellingPlanId ? el.getCurrentSellingPlanId() : '';
      };
    }

    /* 2. After product-form custom element is defined, patch this.cart
          on our specific instance if it was not set (or set to null). */
    function patchCart() {
      var pfEl = document.querySelector('#ProductInfo-{{ section.id }} product-form');
      if (!pfEl) return;
      if (!pfEl.cart) {
        pfEl.cart = document.querySelector('cart-notification') || document.querySelector('cart-drawer');
      }
    }

    if (customElements.get('product-form')) {
      patchCart();
    } else {
      customElements.whenDefined('product-form').then(patchCart);
    }
  })();
</script>

{%- if first_3d_model -%}
  <script type="application/json" id="ProductJSON-{{ product.id }}">
    {{ product.media | where: 'media_type', 'model' | json }}
  </script>
  <script src="{{ 'product-model.js' | asset_url }}" defer></script>
{%- endif -%}

<script type="application/ld+json">
{
  "@context": "http://schema.org/",
  "@type": "Product",
  "name": {{ product.title | json }},
  "url": {{ request.origin | append: product.url | json }},
  {%- if product.featured_image -%}
  "image": [{{ product.featured_image | image_url: width: 1200 | prepend: 'https:' | json }}],
  {%- endif -%}
  "description": {{ product.description | strip_html | truncate: 500 | json }},
  "sku": {{ product.selected_or_first_available_variant.sku | json }},
  "brand": { "@type": "Brand", "name": {{ product.vendor | json }} },
  "offers": {
    "@type": "Offer",
    "priceCurrency": {{ cart.currency.iso_code | json }},
    "price": {{ product.selected_or_first_available_variant.price | divided_by: 100.0 | json }},
    "availability": "http://schema.org/{% if product.selected_or_first_available_variant.available %}InStock{% else %}OutOfStock{% endif %}",
    "url": {{ request.origin | append: product.url | json }}
  }
}
</script>

